ry.append(result)\n\n        return result\n\n\n    def format_response(self, result: Dict[str, Any]) -> str:\n        \"\"\"Format result for display\"\"\"\n        output = []\n\n        output.append(f\"**Query:** {result['query']}\\n\")\n        output.append(f\"**Answer:**\\n{result['answer']}\\n\")\n\n        # Show citations\n        if result['context']:\n            output.append(f\"\\n**Sources ({len(result['context'])}):**\")\n            for i, ctx in enumerate(result['context'][:5], 1):\n                payload = ctx['payload']\n                output.append(\n                    f\"{i}. `{payload['file_path']}` \"\n                    f\"(lines {payload['start_line']}-{payload['end_line']}) \"\n                    f\"[score: {ctx['score']:.3f}]\"\n                )\n\n        # Show tool results\n        if result.get('tool_results'):\n            output.append(f\"\\n**Tool Results:**\")\n            for tool_result in result['tool_results']:\n                output.append(f\"```\\n{tool_result}\\n```\")\n\n        # Show metrics\n        output.append(\n            f\"\\n   **Metrics:** {result['latency']:.2f}s | \"\n            f\"{result['tokens_used']} tokens\"\n        )\n\n        return '\\n'.join(output)\n\n\n# Initialize analyst\nanalyst = CodebaseAnalyst(\n    hybrid_retriever=hybrid_retriever,\n    llm_engine=llm_engine,\n    code_tools=code_tools,\n    cache_manager=cache_manager,\n    monitor=monitor\n)\n\nprint(\"✅ Codebase Analyst initialized\")\n\n# Test query\nprint(\"\\n\" + \"=\"*80)\nprint(\"TESTING ANALYST\")\nprint(\"=\"*80 + \"\\n\")\n\ntest_result = analyst.analyze(\n    \"Where is dependency injection handled in FastAPI?\",\n    use_cache=True,\n    use_tools=False\n)\n\nprint(analyst.format_response(test_result))\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:07:27.541230Z","iopub.execute_input":"2025-10-29T02:07:27.541423Z","iopub.status.idle":"2025-10-29T02:07:39.653305Z","shell.execute_reply.s