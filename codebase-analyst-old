dir)\n\n\n# Initialize config\nconfig = Config()\nconfig.ensure_dirs()\n\nprint(f\"✅ Configuration initialized\")\nprint(f\"📂 Working directory: {config.work_dir}\")\nprint(f\"🔧 GPU available: {config.use_gpu}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:05:43.126508Z","iopub.execute_input":"2025-10-29T02:05:43.127092Z","iopub.status.idle":"2025-10-29T02:05:43.139438Z","shell.execute_reply.started":"2025-10-29T02:05:43.127066Z","shell.execute_reply":"2025-10-29T02:05:43.138504Z"},"id":"8c0bFY3uVX5Q","outputId":"b69c339d-e113-4713-81d3-8bf33b7e32b8"},"outputs":[{"name":"stdout","text":"📁 Verified directories: /kaggle/working/data /kaggle/working/index /kaggle/working/cache\n✅ Configuration initialized\n📂 Working directory: /kaggle/working\n🔧 GPU available: True\n","output_type":"stream"}],"execution_count":29},{"cell_type":"code","source":"#Tree-sitter Parser & Code Extraction\n\nclass CodeParser:\n    \"\"\"Parse source code using tree-sitter and Python AST\"\"\"\n\n    def __init__(self):\n        self.supported_extensions = {\n            '.py': 'python',\n            '.js': 'javascript',\n            '.ts': 'typescript',\n            '.java': 'java',\n            '.cpp': 'cpp',\n            '.c': 'c',\n        }\n\n    def parse_file(self, file_path: Path) -> Dict[str, Any]:\n        \"\"\"Parse a source file and extract structured information\"\"\"\n        try:\n            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:\n                content = f.read()\n\n            # Skip if too large\n            if len(content) > config.max_file_size:\n                return None\n\n            ext = file_path.suffix\n            if ext not in self.supported_extensions:\n                return None\n\n            # For Python, use AST\n            if ext == '.py':\n                return self._parse_python(file_path, content)\n            else:\n                # For other languages, use simple extraction\n                return self._parse_generic(file_path, content)\n\n        except Exception as e:\n            print(f\"Error parsing {file_path}: {e}\")\n            return None\n\n    def _parse_python(self, file_path: Path, content: str) -> Dict[str, Any]:\n        \"\"\"Parse Python file using AST\"\"\"\n        try:\n            tree = python_ast.parse(content)\n\n            functions = []\n            classes = []\n            imports = []\n\n            for node in python_ast.walk(tree):\n                if isinstance(node, python_ast.FunctionDef):\n                    functions.append({\n                        'name': node.name,\n                        'lineno': node.lineno,\n                        'docstring': python_ast.get_docstring(node),\n                        'args': [arg.arg for arg in node.args.args],\n                    })\n                elif isinstance(node, python_ast.ClassDef):\n                    classes.append({\n                        'name': node.name,\n                        'lineno': node.lineno,\n                        'docstring': python_ast.get_docstring(node),\n                        'methods': [m.name for m in node.body if isinstance(m, python_ast.FunctionDef)]\n                    })\n                elif isinstance(node, (python_ast.Import, python_ast.ImportFrom)):\n                    if isinstance(node, python_ast.Import):\n                        imports.extend([alias.name for alias in node.names])\n                    else:\n                        imports.append(node.module)\n\n            return {\n                'file_path': str(file_path),\n                'language': 'python',\n                'content': content,\n                'functions': functions,\n                'classes': classes,\n                'imports': imports,\n                'lines': len(content.split('\\n'))\n            }\n        except SyntaxError:\n            return self._parse_generic(file_path, content)\n\n    def _parse_generic(self, file_path: Path, content: str) -> Dict[str, Any]:\n        \"\"\"Generic parsing for non-Python files\"\"\"\n        return {\n            'file_path': str(file_path),\n            'language': self.supported_extensions.get(file_path.suffix, 'unknown'),\n            'content': content,\n            'functions': [],\n            'classes': [],\n            'imports': [],\n            'lines': len(content.split('\\n'))\n        }\n\n# Test\nparser = CodeParser()\nprint(\"Code parser initialized\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:05:43.140406Z","iopub.execute_input":"2025-10-29T02:05:43.140566Z","iopub.status.idle":"2025-10-29T02:05:43.157712Z","shell.execute_reply.started":"2025-10-29T02:05:43.140554Z","shell.execute_reply":"2025-10-29T02:05:43.157046Z"},"id":"BtqggqUKVX5R","outputId":"4061de7f-97ab-4833-be34-0aea6134e40a"},"outputs":[{"name":"stdout","text":"Code parser initialized\n","output_type":"stream"}],"execution_count":30},{"cell_type":"code","source":"# =============================================================================\n# Complete, Working Module: Repo Selector + CLI + Reindexing + Minimal Indexers\n# (Updated: adds CodebaseAnalyst.analyze / analyze_query / __call__ aliases,\n#           returns rich results with context & scores,\n#           HybridRetriever.search now returns payloads WITH scores)\n# =============================================================================\n\nfrom __future__ import annotations\nimport os\nimport re\nimport json\nimport math\nimport gc\nimport sys\nimport time\nimport pickle\nimport shutil\nimport hashlib\nimport subprocess\nfrom dataclasses import dataclass, field\nfrom typing import List, Dict, Any, Optional, Iterable, Tuple\nfrom pathlib import Path\n\n# Optional Jupyter UI (safe to import even outside notebooks)\ntry:\n    import ipywidgets as widgets\n    from IPython.display import display, clear_output\nexcept Exception:\n    widgets = None\n    def display(*a, **k): pass\n    def clear_output(*a, **k): pass\n\n# Progress bar (fallback if tqdm absent)\ntry:\n    from tqdm import tqdm\nexcept Exception:\n    def tqdm(iterable, **kwargs):\n        return iterable\n\nimport numpy as np\n\n# ---------------------------\n# Basic Config\n# ---------------------------\n@dataclass\nclass Config:\n    # Repo\n    repo_url: str = \"https://github.com/tiangolo/fastapi.git\"\n    repo_name: str = \"fastapi\"\n\n    # Storage locations\n    root_dir: Path = field(default_factory=lambda: Path.cwd())\n    data_dir: Path = field(default_factory=lambda: Path.cwd() / \"data\")\n    index_dir: Path = field(default_factory=lambda: Path.cwd() / \"index\")\n    cache_dir: Path = field(default_factory=lambda: Path.cwd() / \"cache\")\n\n    # Embeddings\n    embedding_model: str = \"minihash-512\"   # placeholder name\n    use_gpu: bool = False\n    batch_size: int = 32\n\n    # Chunking\n    max_lines_per_chunk: int = 200\n\n    def ensure_dirs(self):\n        self.data_dir.mkdir(parents=True, exist_ok=True)\n        self.index_dir.mkdir(parents=True, exist_ok=True)\n        self.cache_dir.mkdir(parents=True, exist_ok=True)\n\n# ---------------------------\n# Utility: Language detection (by extension)\n# ---------------------------\nEXT_TO_LANG = {\n    \".py\": \"python\", \".js\": \"javascript\", \".ts\": \"typescript\", \".tsx\": \"typescript\",\n    \".jsx\": \"javascript\", \".java\": \"java\", \".go\": \"go\", \".rs\": \"rust\", \".cpp\": \"cpp\",\n    \".cxx\": \"cpp\", \".cc\": \"cpp\", \".c\": \"c\", \".h\": \"c\", \".hpp\": \"cpp\", \".cs\": \"csharp\",\n    \".rb\": \"ruby\", \".php\": \"php\", \".swift\": \"swift\", \".kt\": \"kotlin\", \".scala\": \"scala\",\n    \".sh\": \"bash\", \".yaml\": \"yaml\", \".yml\": \"yaml\", \".toml\": \"toml\", \".json\": \"json\",\n    \".md\": \"markdown\", \".txt\": \"text\"\n}\nCODE_EXTS = set(EXT_TO_LANG.keys())\n\ndef guess_language(path: Path) -> str:\n    return EXT_TO_LANG.get(path.suffix.lower(), \"text\")\n\n# ---------------------------\n# Repository Ingester\n# ---------------------------\nclass RepositoryIngester:\n    def __init__(self, config: Config):\n        self.config = config\n        self.config.ensure_dirs()\n\n    def clone_repository(self, repo_url: str, repo_dir: Path) -> Path:\n        if repo_dir.exists():\n            print(f\"📁 Repository already present at: {repo_dir}\")\n            return repo_dir\n        print(f\"⬇️  Cloning {repo_url} → {repo_dir}\")\n        repo_dir.parent.mkdir(parents=True, exist_ok=True)\n        try:\n            subprocess.run(\n                [\"git\", \"clone\", \"--depth\", \"1\", repo_url, str(repo_dir)],\n                check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE\n            )\n        except Exception as e:\n            raise RuntimeError(f\"Git clone failed: {e}\")\n        return repo_dir\n\n    def scan_repository(self, repo_dir: Path) -> List[Path]:\n        print(\"🔎 Scanning repository for code files...\")\n        code_paths: List[Path] = []\n        for root, dirs, files in os.walk(repo_dir):\n            # Skip common large/noise dirs\n            if any(sk in root for sk in [\".git\", \".venv\", \"node_modules\", \"dist\", \"build\", \"__pycache__\"]):\n                continue\n            for fn in files:\n                p = Path(root) / fn\n                if p.suffix.lower() in CODE_EXTS:\n                    code_paths.append(p)\n        print(f\"📄 Found {len(code_paths)} code files\")\n        return code_paths\n\n    def process_files(self, code_files: List[Path]) -> List[Dict[str, Any]]:\n        print(\"🧩 Parsing files...\")\n        docs = []\n        for p in tqdm(code_files, desc=\"Reading files\"):\n            try:\n                text = p.read_text(encoding=\"utf-8\", errors=\"ignore\")\n            except Exception:\n                continue\n            docs.append({\n                \"file_path\": str(p),\n                \"language\": guess_language(p),\n                \"content\": text,\n            })\n        return docs\n\n    def chunk_document(self, doc: Dict[str, Any], max_lines: Optional[int] = None) -> List[Dict[str, Any]]:\n        if max_lines is None:\n            max_lines = self.config.max_lines_per_chunk\n        lines = doc[\"content\"].splitlines()\n        chunks = []\n        i = 0\n        chunk_idx = 0\n        while i < len(lines):\n            block = lines[i:i+max_lines]\n            start_line = i + 1\n            end_line = i + len(block)\n            chunk_id = f\"{doc['file_path']}::chunk_{chunk_idx}\"\n            chunks.append({\n                \"chunk_id\": chunk_id,\n                \"file_path\": doc[\"file_path\"],\n                \"language\": doc[\"language\"],\n                \"content\": \"\\n\".join(block),\n                \"start_line\": start_line,\n                \"end_line\": end_line,\n                # Optional: naive function/class extraction\n                \"functions\": [],\n                \"classes\": [],\n            })\n            i += max_lines\n            chunk_idx += 1\n        return chunks\n\n# ---------------------------\n# Embedding Engine (minimal, deterministic)\n# ---------------------------\nclass EmbeddingEngine:\n    \"\"\"\n    Minimal embedding engine. For portability, we avoid heavy deps.\n    - If you later swap to real embeddings (OpenAI, Cohere, SBERT), keep the API.\n    \"\"\"\n    def __init__(self, model_name: str = \"minihash-512\", use_gpu: bool = False):\n        self.model_name = model_name\n        self.use_gpu = use_gpu\n        self.dimension = 512  # fixed small dim\n\n    def _minihash_vec(self, text: str) -> np.ndarray:\n        # simple, deterministic vector based on multiple hash seeds\n        vec = np.zeros(self.dimension, dtype=np.float32)\n        for seed in (17, 101, 313, 997):\n            h = int(hashlib.md5((str(seed) + text).encode()).hexdigest(), 16)\n            for i in range(self.dimension):\n                # spread the bits\n                vec[i] += ((h >> (i % 64)) & 1)\n        # normalize\n        norm = np.linalg.norm(vec) + 1e-8\n        return (vec / norm).astype(np.float32)\n\n    def encode(self, texts: List[str], batch_size: int = 32, show_progress: bool = True) -> np.ndarray:\n        out = []\n        iterator = tqdm(range(0, len(texts), batch_size), desc=\"Embedding\", disable=not show_progress)\n        for i in iterator:\n            batch = texts[i:i+batch_size]\n            for t in batch:\n                out.append(self._minihash_vec(t))\n        return np.vstack(out)\n\n# ---------------------------\n# Vector Store (simple in-memory cosine index)\n# ---------------------------\nclass VectorStore:\n    def __init__(self, collection_name: str, dimension: int, path: Path):\n        self.collection_name = collection_name\n        self.dimension = dimension\n        self.path = path\n        self._embeddings: Optional[np.ndarray] = None\n        self._payloads: List[Dict[str, Any]] = []\n\n    def _create_collection(self):\n        # Reset the in-memory store\n        self._embeddings = None\n        self._payloads = []\n\n    def add_vectors(self, embeddings: np.ndarray, payloads: List[Dict[str, Any]], batch_size: int = 100):\n        assert embeddings.shape[0] == len(payloads)\n        if self._embeddings is None:\n            self._embeddings = embeddings.astype(np.float32)\n        else:\n            self._embeddings = np.vstack([self._embeddings, embeddings.astype(np.float32)])\n        self._payloads.extend(payloads)\n\n    def search(self, query_vec: np.ndarray, top_k: int = 10) -> List[Tuple[float, Dict[str, Any]]]:\n        if self._embeddings is None or len(self._payloads) == 0:\n            return []\n        # cosine similarity\n        A = self._embeddings\n        q = query_vec / (np.linalg.norm(query_vec) + 1e-8)\n        sims = (A @ q) / (np.linalg.norm(A, axis=1) + 1e-8)\n        idx = np.argsort(-sims)[:top_k]\n        return [(float(sims[i]), self._payloads[i]) for i in idx]\n\n# ---------------------------\n# Sparse Retriever (TF-IDF)\n# ---------------------------\nclass SparseRetriever:\n    def __init__(self):\n        self.vocab: Dict[str, int] = {}\n        self.doc_freq: Dict[int, int] = {}\n        self.docs: List[Dict[str, Any]] = []\n        self.doc_term_counts: List[Dict[int, int]] = []\n        self.N = 0\n\n    @staticmethod\n    def _tokenize(text: str) -> List[str]:\n        return re.findall(r\"[A-Za-z_][A-Za-z0-9_\\-\\.]{1,64}\", text)\n\n    def index(self, chunks: List[Dict[str, Any]]):\n        print(\"🧮 Building sparse index (TF-IDF)...\")\n        self.docs = chunks\n        self.N = len(chunks)\n        self.doc_term_counts = []\n        self.vocab = {}\n        self.doc_freq = {}\n        # build vocab\n        for chunk in tqdm(chunks, desc=\"Sparse vocab\"):\n            terms = self._tokenize(chunk[\"content\"].lower())\n            counts: Dict[int, int] = {}\n            seen_terms = set()\n            for t in terms:\n                if t not in self.vocab:\n                    self.vocab[t] = len(self.vocab)\n                tid = self.vocab[t]\n                counts[tid] = counts.get(tid, 0) + 1\n                if tid not in seen_terms:\n                    self.doc_freq[tid] = self.doc_freq.get(tid, 0) + 1\n                    seen_terms.add(tid)\n            self.doc_term_counts.append(counts)\n\n    def search(self, query: str, top_k: int = 10) -> List[Tuple[float, Dict[str, Any]]]:\n        if self.N == 0:\n            return []\n        q_terms = self._tokenize(query.lower())\n        q_counts: Dict[int, int] = {}\n        for t in q_terms:\n            if t in self.vocab:\n                tid = self.vocab[t]\n                q_counts[tid] = q_counts.get(tid, 0) + 1\n\n        # Compute cosine similarity in TF-IDF space (sparse)\n        def tfidf(count, df):  # basic tf-idf\n            idf = math.log((self.N + 1) / (1 + df)) + 1.0\n            return count * idf\n\n        q_vec: Dict[int, float] = {tid: tfidf(c, self.doc_freq.get(tid, 1)) for tid, c in q_counts.items()}\n        q_norm = math.sqrt(sum(v*v for v in q_vec.values())) + 1e-8\n\n        scores = []\n        for i, counts in enumerate(self.doc_term_counts):\n            dot = 0.0\n            d_norm = 0.0\n            for tid, c in counts.items():\n                w = tfidf(c, self.doc_freq.get(tid, 1))\n                d_norm += w*w\n                if tid in q_vec:\n                    dot += w * q_vec[tid]\n            d_norm = math.sqrt(d_norm) + 1e-8\n            sim = dot / (q_norm * d_norm)\n            scores.append((sim, self.docs[i]))\n\n        scores.sort(key=lambda x: -x[0])\n        return scores[:top_k]\n\n# ---------------------------\n# Hybrid Retriever\n# ---------------------------\nclass HybridRetriever:\n    def __init__(self, vector_store: VectorStore, sparse_retriever: SparseRetriever,\n                 embedding_engine: EmbeddingEngine, dense_weight: float = 0.5):\n        self.vector_store = vector_store\n        self.sparse = sparse_retriever\n        self.embedding_engine = embedding_engine\n        self.dense_weight = dense_weight\n\n    def search(self, query: str, top_k: int = 10) -> List[Dict[str, Any]]:\n        # Dense\n        qvec = self.embedding_engine.encode([query], batch_size=1, show_progress=False)[0]\n        dense_hits = self.vector_store.search(qvec, top_k=top_k*3)  # [(score, payload), ...]\n        # Sparse\n        sparse_hits = self.sparse.search(query, top_k=top_k*3)      # [(score, payload), ...]\n\n        # Score fusion (normalize each to [0,1], then weighted sum)\n        def normalize(scores):\n            if not scores: return []\n            vals = [s for s,_ in scores]\n            mn, mx = min(vals), max(vals)\n            if mx - mn < 1e-8:\n                return [(0.5, p) for s,p in scores]\n            return [((s - mn) / (mx - mn), p) for s,p in scores]\n\n        dense_n = normalize(dense_hits)\n        sparse_n = normalize(sparse_hits)\n\n        # Index by chunk_id\n        score_map: Dict[str, float] = {}\n        payload_map: Dict[str, Dict[str, Any]] = {}\n\n        for s, p in dense_n:\n            cid = p[\"chunk_id\"]\n            score_map[cid] = score_map.get(cid, 0.0) + self.dense_weight * s\n            payload_map[cid] = p\n        for s, p in sparse_n:\n            cid = p[\"chunk_id\"]\n            score_map[cid] = score_map.get(cid, 0.0) + (1 - self.dense_weight) * s\n            payload_map[cid] = p\n\n        fused = sorted(score_map.items(), key=lambda x: -x[1])[:top_k]\n        # Return payloads WITH fused score (non-mutating copy)\n        out: List[Dict[str, Any]] = []\n        for cid, sc in fused:\n            p = payload_map[cid]\n            out.append({\n                \"chunk_id\": p[\"chunk_id\"],\n                \"file_path\": p[\"file_path\"],\n                \"language\": p[\"language\"],\n                \"content\": p[\"content\"],\n                \"start_line\": p[\"start_line\"],\n                \"end_line\": p[\"end_line\"],\n                \"score\": float(sc),\n                \"functions\": p.get(\"functions\", []),\n                \"classes\": p.get(\"classes\", []),\n            })\n        return out\n\n# ---------------------------\n# Minimal Code Tools\n# ---------------------------\nclass CodeTools:\n    def __init__(self, repo_dir: Path, chunks: List[Dict[str, Any]]):\n        self.repo_dir = Path(repo_dir)\n        self.chunks = chunks\n\n    def open_file(self, file_path: str, start_line: Optional[int] = None, end_line: Optional[int] = None) -> str:\n        p = Path(file_path)\n        text = p.read_text(encoding=\"utf-8\", errors=\"ignore\")\n        if start_line or end_line:\n            lines = text.splitlines()\n            s = (start_line or 1) - 1\n            e = end_line or len(lines)\n            return \"\\n\".join(lines[s:e])\n        return text\n\n    def grep_symbol(self, symbol: str) -> List[Dict[str, Any]]:\n        hits = []\n        for ch in self.chunks:\n            if symbol in ch[\"content\"]:\n                hits.append(ch)\n        return hits\n\n#-------------------------\n# Semantic cache implementation\n#--------------------------\n\nimport re, hashlib, numpy as np\n\n# --- Helper: text normalization ---\ndef normalize_query(query: str) -> str:\n    q = query.strip().lower()\n    q = re.sub(r\"[^a-z0-9\\s]\", \"\", q)\n    return q\n\n# --- New Semantic Cache class ---\nclass SemanticCache:\n    def __init__(self, embedding_engine, similarity_threshold=0.95):\n        \"\"\"\n        embedding_engine: same engine used in your retriever (so embeddings align)\n        similarity_threshold: cosine threshold for considering cache match\n        \"\"\"\n        self.embedding_engine = embedding_engine\n        self.similarity_threshold = similarity_threshold\n        self.cache = {}           # {key: {\"embedding\": np.array, \"value\": result}}\n        self.keys = []            # maintain order for iteration\n\n    def _cosine_sim(self, a, b):\n        return float(np.dot(a, b) / (np.linalg.norm(a)*np.linalg.norm(b) + 1e-8))\n\n    def get(self, query: str):\n        if not self.cache:\n            return None\n\n        norm_q = normalize_query(query)\n        query_vec = self.embedding_engine.encode([norm_q], show_progress=False)[0]\n\n        # Compare with all cached entries\n        best_sim = 0\n        best_val = None\n        for key, data in self.cache.items():\n            sim = self._cosine_sim(query_vec, data[\"embedding\"])\n            if sim > best_sim:\n                best_sim, best_val = sim, data[\"value\"]\n\n        if best_sim >= self.similarity_threshold:\n            print(f\"🧠 Semantic cache HIT (sim={best_sim:.3f})\")\n            return best_val\n        return None\n\n    def set(self, query: str, value, ttl=None):\n        norm_q = normalize_query(query)\n        query_vec = self.embedding_engine.encode([norm_q], show_progress=False)[0]\n        hashed_key = hashlib.md5(norm_q.encode()).hexdigest()\n        self.cache[hashed_key] = {\"embedding\": query_vec, \"value\": value}\n        self.keys.append(hashed_key)\n\n\n\n\n\n\n\n\n\n\n\n# ---------------------------\n# Lightweight Codebase Analyst (LLM-agnostic)\n# ---------------------------\nclass CodebaseAnalyst:\n    def __init__(self, hybrid_retriever: HybridRetriever,\n                 llm_engine,  # must provide .generate(prompt, context=[...])\n                 code_tools: CodeTools,\n                 cache_manager=None, monitor=None):\n        self.retriever = hybrid_retriever\n        self.llm = llm_engine\n        self.tools = code_tools\n        self.cache = cache_manager\n        self.monitor = monitor\n\n    # --- Core internal run ---\n    def _run(self, question: str, top_k: int = 8) -> Dict[str, Any]:\n        t0 = time.time()\n        hits = self.retriever.search(question, top_k=top_k)  # each hit has 'score'\n        context = []\n        for h in hits:\n            context.append({\n                \"payload\": {\n                    \"chunk_id\": h[\"chunk_id\"],\n                    \"file_path\": h[\"file_path\"],\n                    \"language\": h[\"language\"],\n                    \"content\": h[\"content\"],\n                    \"start_line\": h[\"start_line\"],\n                    \"end_line\": h[\"end_line\"],\n                },\n                \"score\": h.get(\"score\", 0.0)\n            })\n        llm_t0 = time.time()\n        out = self.llm.generate(\n            prompt=question,\n            context=[{\"payload\": c[\"payload\"]} for c in context],\n            max_tokens=1024,\n            temperature=0.2,\n            tools=None\n        )\n        llm_t1 = time.time()\n        t1 = time.time()\n\n        # Normalize structure expected by your Gradio UI\n        result = {\n            \"answer\": out.get(\"content\", \"\"),\n            \"content\": out.get(\"content\", \"\"),\n            \"tool_calls\": out.get(\"tool_calls\"),\n            \"tokens_used\": out.get(\"tokens_used\", 0),\n            \"latency\": float(t1 - t0),\n            \"llm_latency\": float(llm_t1 - llm_t0),\n            \"context\": context\n        }\n        return result\n\n    # --- Backward-compatible public APIs ---\n    def answer(self, question: str, top_k: int = 8) -> Dict[str, Any]:\n        \"\"\"Original minimal API (kept). Returns the LLM output dict.\"\"\"\n        res = self._run(question, top_k=top_k)\n        # For backward compatibility: return just the LLM dict-like shape\n        return {\n            \"content\": res[\"answer\"],\n            \"tool_calls\": res[\"tool_calls\"],\n            \"tokens_used\": res[\"tokens_used\"]\n        }\n\n    def analyze(self, query: str, use_cache: bool = True, use_tools: bool = False, top_k: int = 8) -> Dict[str, Any]:\n        \"\"\"Alias expected by your Gradio UI.\"\"\"\n        return self._run(query, top_k=top_k)\n\n    def analyze_query(self, query: str, use_cache: bool = True, use_tools: bool = False, top_k: int = 8) -> Dict[str, Any]:\n        \"\"\"Another common alias name used by some notebooks.\"\"\"\n        return self._run(query, top_k=top_k)\n\n    def __call__(self, query: str, use_cache: bool = True, use_tools: bool = False, top_k: int = 8) -> Dict[str, Any]:\n        \"\"\"Callable interface that forwards to analyze().\"\"\"\n        return self._run(query, top_k=top_k)\n\n# ---------------------------\n# Repository Selector UI (your original, slightly guarded for None widgets)\n# ---------------------------\nclass RepositorySelector:\n    \"\"\"Interactive repository selector and reindexer\"\"\"\n    def __init__(self, config: Config):\n        self.config = config\n        self.current_repo_url = config.repo_url\n        self.current_repo_name = config.repo_name\n        self.preset_repos = {\n            \"FastAPI\": \"https://github.com/tiangolo/fastapi.git\",\n            \"Flask\": \"https://github.com/pallets/flask.git\",\n            \"Django\": \"https://github.com/django/django.git\",\n            \"Requests\": \"https://github.com/psf/requests.git\",\n            \"NumPy\": \"https://github.com/numpy/numpy.git\",\n            \"Pandas\": \"https://github.com/pandas-dev/pandas.git\",\n            \"Scikit-learn\": \"https://github.com/scikit-learn/scikit-learn.git\",\n            \"TensorFlow\": \"https://github.com/tensorflow/tensorflow.git\",\n            \"PyTorch\": \"https://github.com/pytorch/pytorch.git\",\n            \"Transformers\": \"https://github.com/huggingface/transformers.git\",\n            \"LangChain\": \"https://github.com/langchain-ai/langchain.git\",\n            \"Custom\": \"custom\"\n        }\n\n    def create_ui(self):\n        if widgets is None:\n            print(\"ipywidgets not available in this environment.\")\n            return\n\n        self.repo_dropdown = widgets.Dropdown(\n            options=list(self.preset_repos.keys()),\n            value=\"FastAPI\",\n            description='Preset:',\n            style={'description_width': 'initial'}\n        )\n        self.custom_url_input = widgets.Text(\n            value=self.config.repo_url,\n            placeholder='https://github.com/username/repo.git',\n            description='Custom URL:',\n            disabled=True,\n            layout=widgets.Layout(width='600px'),\n            style={'description_width': 'initial'}\n        )\n        self.repo_name_input = widgets.Text(\n            value=self.config.repo_name,\n            placeholder='Repository name',\n            description='Repo Name:',\n            layout=widgets.Layout(width='300px'),\n            style={'description_width': 'initial'}\n        )\n        self.load_button = widgets.Button(\n            description='Load Repository',\n            button_style='success',\n            tooltip='Clone and index the selected repository',\n            icon='download'\n        )\n        self.status_output = widgets.Output()\n\n        self.repo_dropdown.observe(self._on_dropdown_change, names='value')\n        self.load_button.on_click(self._on_load_click)\n\n        ui = widgets.VBox([\n            widgets.HTML(\"<h3>🔧 Repository Configuration</h3>\"),\n            widgets.HTML(\"<p>Select a preset repository or enter a custom GitHub URL:</p>\"),\n            self.repo_dropdown,\n            self.custom_url_input,\n            self.repo_name_input,\n            self.load_button,\n            self.status_output\n        ])\n        display(ui)\n\n    def _on_dropdown_change(self, change):\n        selected = change['new']\n        if selected == \"Custom\":\n            self.custom_url_input.disabled = False\n            self.custom_url_input.value = \"\"\n        else:\n            self.custom_url_input.disabled = True\n            self.custom_url_input.value = self.preset_repos[selected]\n            self.repo_name_input.value = selected.lower()\n\n    def _on_load_click(self, button):\n        with self.status_output:\n            clear_output()\n            if self.repo_dropdown.value == \"Custom\":\n                url = self.custom_url_input.value.strip()\n                if not url:\n                    print(\"❌ Please enter a custom URL\")\n                    return\n            else:\n                url = self.preset_repos[self.repo_dropdown.value]\n            name = self.repo_name_input.value.strip()\n            if not name:\n                print(\"❌ Please enter a repository name\")\n                return\n            self.config.repo_url = url\n            self.config.repo_name = name\n            self.current_repo_url = url\n            self.current_repo_name = name\n            print(f\"✅ Configuration updated:\")\n            print(f\"   URL: {url}\")\n            print(f\"   Name: {name}\")\n            print(f\"\\n⚠️  Please run the reindexing cells below to process this repository\")\n\n    def get_current_config(self):\n        return {'url': self.current_repo_url, 'name': self.current_repo_name}\n\n# ---------------------------\n# CLI Alternative\n# ---------------------------\ndef configure_repository_cli(preset: str = None, custom_url: str = None,\n                            repo_name: str = None,\n                            config: Optional[Config] = None) -> Config:\n    presets = {\n        \"fastapi\": \"https://github.com/tiangolo/fastapi.git\",\n        \"flask\": \"https://github.com/pallets/flask.git\",\n        \"django\": \"https://github.com/django/django.git\",\n        \"requests\": \"https://github.com/psf/requests.git\",\n        \"numpy\": \"https://github.com/numpy/numpy.git\",\n        \"pandas\": \"https://github.com/pandas-dev/pandas.git\",\n        \"sklearn\": \"https://github.com/scikit-learn/scikit-learn.git\",\n        \"tensorflow\": \"https://github.com/tensorflow/tensorflow.git\",\n        \"pytorch\": \"https://github.com/pytorch/pytorch.git\",\n        \"transformers\": \"https://github.com/huggingface/transformers.git\",\n        \"langchain\": \"https://github.com/langchain-ai/langchain.git\",\n    }\n    conf = config or Config()\n    if preset:\n        p = preset.lower()\n        if p in presets:\n            conf.repo_url = presets[p]\n            conf.repo_name = p\n            print(f\"✅ Using preset: {preset}\")\n        else:\n            print(f\"❌ Unknown preset: {preset}\")\n            print(f\"Available presets: {', '.join(presets.keys())}\")\n            return conf\n    elif custom_url and repo_name:\n        conf.repo_url = custom_url\n        conf.repo_name = repo_name\n        print(f\"✅ Using custom repository:\\n   URL: {custom_url}\\n   Name: {repo_name}\")\n    else:\n        print(\"❌ Please provide either 'preset' or both 'custom_url' and 'repo_name'\")\n    return conf\n\n# ---------------------------\n# Reindexing Pipeline\n# ---------------------------\ndef reindex_repository(config: Config,\n                       ingester: RepositoryIngester = None,\n                       embedding_engine: EmbeddingEngine = None,\n                       vector_store: VectorStore = None,\n                       sparse_retriever: SparseRetriever = None,\n                       force_reclone: bool = False):\n    \"\"\"\n    Reindex a repository after configuration change.\n    \"\"\"\n    print(\"\\n\" + \"=\"*80)\n    print(f\"REINDEXING REPOSITORY: {config.repo_name}\")\n    print(\"=\"*80 + \"\\n\")\n\n    config.ensure_dirs()\n    if ingester is None:\n        ingester = RepositoryIngester(config)\n\n    # Clone or reuse\n    repo_dir = config.data_dir / config.repo_name\n    if force_reclone and repo_dir.exists():\n        print(f\"🗑️  Removing existing repository at {repo_dir}\")\n        shutil.rmtree(repo_dir)\n    repo_dir = ingester.clone_repository(config.repo_url, repo_dir)\n\n    # Scan & parse\n    code_files = ingester.scan_repository(repo_dir)\n    parsed_docs = ingester.process_files(code_files)\n\n    # Chunk\n    all_chunks = []\n    for doc in tqdm(parsed_docs, desc=\"Chunking documents\"):\n        chunks = ingester.chunk_document(doc)\n        all_chunks.extend(chunks)\n    print(f\"✅ Created {len(all_chunks)} chunks from {len(parsed_docs)} files\")\n\n    # Cache chunks\n    with open(config.cache_dir / f\"chunks_{config.repo_name}.pkl\", \"wb\") as f:\n        pickle.dump(all_chunks, f)\n\n    # Embeddings\n    if embedding_engine is None:\n        embedding_engine = EmbeddingEngine(config.embedding_model, config.use_gpu)\n\n    print(\"\\n📊 Generating embeddings...\")\n    chunk_texts = [f\"{c['file_path']}\\n{c['content']}\" for c in all_chunks]\n    embeddings = embedding_engine.encode(\n        chunk_texts,\n        batch_size=config.batch_size,\n        show_progress=True\n    )\n\n    # Vector store\n    if vector_store is None:\n        vector_store = VectorStore(\n            collection_name=f\"codebase_{config.repo_name}\",\n            dimension=embedding_engine.dimension,\n            path=config.index_dir\n        )\n    else:\n        vector_store._create_collection()\n\n    payloads = [\n        {\n            'chunk_id': c['chunk_id'],\n            'file_path': c['file_path'],\n            'language': c['language'],\n            'content': c['content'],\n            'start_line': c['start_line'],\n            'end_line': c['end_line'],\n            'functions': [f['name'] for f in c.get('functions', [])],\n            'classes': [cl['name'] for cl in c.get('classes', [])],\n        } for c in all_chunks\n    ]\n    vector_store.add_vectors(embeddings, payloads, batch_size=100)\n\n    # Sparse retriever\n    if sparse_retriever is None:\n        sparse_retriever = SparseRetriever()\n    sparse_retriever.index(all_chunks)\n\n    print(\"\\n✅ Reindexing complete!\")\n    print(f\"📁 Repository: {config.repo_name}\")\n    print(f\"📄 Files: {len(parsed_docs)}\")\n    print(f\"🔢 Chunks: {len(all_chunks)}\")\n    print(f\"🎯 Embeddings: {embeddings.shape}\")\n\n    return {\n        'config': config,\n        'repo_dir': repo_dir,\n        'all_chunks': all_chunks,\n        'embeddings': embeddings,\n        'vector_store': vector_store,\n        'sparse_retriever': sparse_retriever\n    }\n\n# ---------------------------\n# Simple cache/monitor stubs\n# ---------------------------\nclass NullCache:\n    def get(self, k): return None\n    def set(self, k, v, ttl=None): pass\n\nclass NullMonitor:\n    def log(self, **kwargs): pass\n\n# ---------------------------\n# LLM Engine placeholder (expects your real LLMEngine with .generate)\n# If you already have the fused LLMEngine from earlier, import/use it instead.\n# ---------------------------\nclass DummyLLM:\n    def generate(self, prompt: str, context: List[Dict], max_tokens: int = 1024,\n                 temperature: float = 0.2, tools: Optional[List[Dict]] = None) -> Dict[str, Any]:\n        # Minimal deterministic mock to keep pipeline testable\n        files = [ctx['payload']['file_path'] for ctx in context[:3]]\n        return {\n            \"content\": f\"(MOCK) Q: {prompt}\\nTop files: {files}\",\n            \"tool_calls\": None,\n            \"tokens_used\": 0\n        }\n\n# ---------------------------\n# USAGE EXAMPLES (copy into a notebook cell to run)\n# ---------------------------\n\"\"\"\n# --- Option 1: Interactive (Jupyter)\nconfig = Config()\nselector = RepositorySelector(config)\nselector.create_ui()\n# After clicking 'Load Repository', run reindex:\nresult = reindex_repository(config=config)\n\n# Wiring components:\nembedding_engine = EmbeddingEngine()\nhybrid_retriever = HybridRetriever(\n    vector_store=result['vector_store'],\n    sparse_retriever=result['sparse_retriever'],\n    embedding_engine=embedding_engine,\n    dense_weight=0.6\n)\n# Replace DummyLLM with your fused LLMEngine instance:\n# from your_llm_module import LLMEngine\n# llm_engine = LLMEngine(provider=\"openai\", model=\"gpt-4o-mini\", api_key=OPENAI_API_KEY)\nllm_engine = DummyLLM()\n\ncode_tools = CodeTools(result['repo_dir'], result['all_chunks'])\ncache_manager = NullCache()\nmonitor = NullMonitor()\n\nanalyst = CodebaseAnalyst(\n    hybrid_retriever=hybrid_retriever,\n    llm_engine=llm_engine,\n    code_tools=code_tools,\n    cache_manager=cache_manager,\n    monitor=monitor\n)\n\n# Works with any of these:\nres1 = analyst.analyze(\"Where is the main entrypoint defined?\")\nres2 = analyst.analyze_query(\"Where is the main entrypoint defined?\")\nres3 = analyst(\"Where is the main entrypoint defined?\")\n\nprint(res1[\"answer\"])\nprint(\"Context items:\", len(res1[\"context\"]))\nprint(\"Latency (s):\", res1[\"latency\"])\n\n# --- Option 2: CLI style\nconf = configure_repository_cli(preset=\"Flask\")\nresult = reindex_repository(conf)\n\"\"\"\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:05:43.202965Z","iopub.execute_input":"2025-10-29T02:05:43.203234Z","iopub.status.idle":"2025-10-29T02:05:43.293099Z","she