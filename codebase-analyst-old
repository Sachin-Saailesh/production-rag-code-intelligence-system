king\n\nclass HybridRetriever:\n    \"\"\"Combine dense and sparse retrieval with reranking\"\"\"\n\n    def __init__(self, vector_store: VectorStore,\n                 sparse_retriever: SparseRetriever,\n                 embedding_engine: EmbeddingEngine,\n                 cohere_api_key: Optional[str] = None):\n        self.vector_store = vector_store\n        self.sparse_retriever = sparse_retriever\n        self.embedding_engine = embedding_engine\n\n        # Initialize reranker if API key provided\n        self.reranker = None\n        if cohere_api_key:\n            self.reranker = cohere.Client(cohere_api_key)\n\n    def retrieve(self, query: str, top_k_dense: int = 20,\n                top_k_sparse: int = 20, top_k_final: int = 10) -> List[Dict]:\n        \"\"\"Hybrid retrieval with optional reranking\"\"\"\n\n        # Dense retrieval\n        query_embedding = self.embedding_engine.encode_query(query)\n        dense_results = self.vector_store.search(query_embedding, top_k_dense)\n\n        # Sparse retrieval\n        sparse_results = self.sparse_retriever.search(query, top_k_sparse)\n\n        # Merge results\n        merged = self._merge_results(dense_results, sparse_results)\n\n        # Rerank if available\n        if self.reranker and len(merged) > 0:\n            merged = self._rerank(query, merged, top_k_final)\n        else:\n            merged = merged[:top_k_final]\n\n        return merged\n\n    def _merge_results(self, dense: List[Dict], sparse: List[Dict]) -> List[Dict]:\n        \"\"\"Merge and deduplicate results using reciprocal rank fusion\"\"\"\n        scores = {}\n\n        # Add dense results\n        for rank, result in enumerate(dense, 1):\n            chunk_id = result['payload']['chunk_id']\n            scores[chunk_id] = scores.get(chunk_id, 0) + 1 / (rank + 60)\n\n        # Add sparse results\n        for rank, result in enumerate(sparse, 1):\n            chunk_id = result['payload']['chunk_id']\n            scores[chunk_id] = scores.get(chunk_id, 0) + 1 / (rank + 60)\n\n        # Sort by combined score\n        sorted_ids = sorted(scores.items(), key=lambda x: x[1], reverse=True)\n\n        # Get full payloads\n        id_to_payload = {}\n        for result in dense + sparse:\n            chunk_id = result['payload']['chunk_id']\n            if chunk_id not in id_to_payload:\n                id_to_payload[chunk_id] = result['payload']\n\n        merged = [\n            {'score': score, 'payload': id_to_payload[chunk_id]}\n            for chunk_id, score in sorted_ids\n            if chunk_id in id_to_payload\n        ]\n\n        return merged\n\n    def _rerank(self, query: str, results: List[Dict], top_k: int) -> List[Dict]:\n        \"\"\"Rerank using Cohere\"\"\"\n        try:\n            documents = [r['payload']['content'] for r in results]\n\n            rerank_response = self.reranker.rerank(\n                query=query,\n                documents=documents,\n                top_n=top_k,\n                model=\"rerank-english-v3.0\"\n            )\n\n            reranked = []\n            for result in rerank_response.results:\n                original = results[result.index]\n                reranked.append({\n                    'score': result.relevance_score,\n                    'payload': original['payload']\n                })\n\n            return reranked\n        except Exception as e:\n            print(f\"Reranking failed: {e}. Using merged results.\")\n            return results[:top_k]\n\n# Initialize hybrid retriever (without Cohere for now)\n# To use Cohere reranking, set your API key:\n# COHERE_API_KEY = \"your-key-here\"\nhybrid_retriever = HybridRetriever(\n    vector_store=vector_store,\n    sparse_retriever=sparse_retriever,\n    embedding_engine=embedding_engine,\n    cohere_api_key=COHERE_API_KEY\n)\n\n# Test retrieval\ntest_query = \"Where is dependency injection handled?\"\ntest_results = hybrid_retriever.retrieve(test_query, top_k_final=5)\n\nprint(f\"