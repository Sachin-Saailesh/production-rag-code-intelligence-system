tions_df = pd.DataFrame(citations) if citations else pd.DataFrame()\n\n            # Performance metrics\n            metrics = f\"\"\"\n**Performance Metrics:**\n- Latency: {result['latency']:.2f}s\n- Tokens Used: {result['tokens_used']}\n- Context Chunks: {len(result['context'])}\n- Cache: {'HIT' if use_cache and analyst.cache.get(f\"query:{query}\") else 'MISS'}\n            \"\"\".strip()\n\n            return response, citations_df, metrics\n\n        except Exception as e:\n            import traceback\n            err = traceback.format_exc()\n            return f\"❌ Error: {str(e)}\\n\\n{err}\", pd.DataFrame(), \"\"\n\n    # --------------------------------------------------------\n    # Repository Loader + Reindexer\n    # --------------------------------------------------------\n    def load_repository(preset, custom_url, repo_name, force_reclone):\n        \"\"\"Load and index a new repository dynamically\"\"\"\n        global config, all_chunks, vector_store, sparse_retriever\n        global hybrid_retriever, code_tools, analyst, repo_dir\n\n        if reindex_state[\"in_progress\"]:\n            return \"⚠️ Reindexing already in progress. Please wait...\"\n\n        reindex_state[\"in_progress\"] = True\n        messages = []\n\n        try:\n            preset_repos = {\n                \"FastAPI\": (\"https://github.com/tiangolo/fastapi.git\", \"fastapi\"),\n                \"Flask\": (\"https://github.com/pallets/flask.git\", \"flask\"),\n                \"Django\": (\"https://github.com/django/django.git\", \"django\"),\n                \"Requests\": (\"https://github.com/psf/requests.git\", \"requests\"),\n                \"NumPy\": (\"https://github.com/numpy/numpy.git\", \"numpy\"),\n                \"Pandas\": (\"https://github.com/pandas-dev/pandas.git\", \"pandas\"),\n                \"Scikit-learn\": (\"https://github.com/scikit-learn/scikit-learn.git\", \"sklearn\"),\n                \"LangChain\": (\"https://github.com/langchain-ai/langchain.git\", \"langchain\"),\n            }\n\n            # Select repo\n            if preset != \"Custom\":\n                url, name = preset_repos[preset]\n            else:\n                if not custom_url or not repo_name:\n                    return \"❌ Please provide both custom URL and repository name\"\n                url = custom_url.strip()\n                name = repo_name.strip()\n\n            # Update config\n            config.repo_url = url\n            config.repo_name = name\n            messages.append(f\"🔄 Loading repository: {name}\")\n            messages.append(f\"📍 URL: {url}\")\n\n            # Run reindex\n            messages.append(\"\\n⏳ Reindexing repository, please wait...\")\n            result = reindex_repository(\n                config=config,\n                ingester=ingester,\n                embedding_engine=embedding_engine,\n                vector_store=vector_store,\n                sparse_retriever=sparse_retriever,\n                force_reclone=force_reclone\n            )\n\n            # Update globals\n            all_chunks = result['all_chunks']\n            vector_store = result['vector_store']\n            sparse_retriever = result['sparse_retriever']\n            repo_dir = result['repo_dir']\n\n            hybrid_retriever = HybridRetriever(\n                vector_store=vector_store,\n                sparse_retriever=sparse_retriever,\n                embedding_engine=embedding_engine\n            )\n\n            code_tools = CodeTools(repo_dir, all_chunks)\n            analyst = CodebaseAnalyst(\n                hybrid_retriever=hybrid_retriever,\n                llm_engine=llm_engine,\n                code_tools=code_tools,\n                cache_manager=cache_manager,\n                monitor=monitor\n            )\n\n            # Clear prefix cache\n            llm_engine.clear_cache()\n\n            messages.append(f\"\\n✅ Repository indexed successfully!\")\n            messages.append(f\"📊 Files: {len(result['all_chunks']) // 5} (approx)\")\n            messages.append(f\"🔢 Chunks: {len(all_chunks):,}\")\n            messages.append(f\"💾 Embeddings: {result['embeddings'].shape}\")\n            messages.append(f\"\\n💡 You can now query the {name} codebase.\")\n\n        except Exception as e:\n            import traceback\n            messages.append(f\"❌ Error: {str(e)}\")\n            messages.append(traceback.format_exc())\n\n        finally:\n            reindex_state[\"in_progress\"] = False\n\n        return \"\\n\".join(messages)\n\n    # --------------------------------------------------------\n    # Monitoring + Tools\n    # --------------------------------------------------------\n    def show_stats():\n        \"\"\"Return runtime performance metrics\"\"\"\n        try:\n            stats = monitor.get_stats()\n            if not stats:\n                return \"No queries yet\"\n            return f\"\"\"\n**System Statistics:**\n- Total Queries: {stats['total_queries']}\n- Average Latency: {stats['avg_latency']:.2f}s\n- P95 Latency: {stats['p95_latency']:.2f}s\n- Average Tokens: {stats['avg_tokens']:.0f}\n- Total Tokens: {stats['total_tokens']:.0f}\n- Cache Hit Rate: {stats['cache_hit_rate']:.1%}\n- Memory Usage: {stats['memory_usage_mb']:.0f} MB\n            \"\"\".strip()\n        except Exception:\n            return \"Monitoring not enabled.\"\n\n    def view_file(file_path, start_line, end_line):\n        try:\n            if not file_path:\n                return \"Please provide a file path\"\n            return code_tools.open_file(file_path, start_line, end_line)\n        except Exception as e:\n            return f\"Error: {str(e)}\"\n\n    def search_symbol(symbol):\n        try:\n            if not symbol:\n                return \"Please enter a symbol name\"\n            results = code_tools.grep_symbol(symbol)\n            return \"\\n\\n\".join([r['file_path'] for r in results[:20]]) or \"No matches found.\"\n        except Exception as e:\n            return f\"Error: {str(e)}\"\n\n    # --------------------------------------------------------\n    # Gradio Layout\n    # --------------------------------------------------------\n    with gr.Blocks(title=\"1M-Token Codebase Analyst\", theme=gr.themes.Soft()) as demo:\n        gr.Markdown(\"\"\"\n        # 🚀 1M-Token Codebase Analyst\n        Analyze and explore massive codebases with hybrid retrieval, caching, and multi-repo support.\n        \"\"\")\n\n        current_repo = gr.Markdown(\n            f\"**Repository:** {config.repo_name} | **Chunks:** {len(all_chunks):,}\"\n        )\n\n        # ---------------- Query Tab ----------------\n        with gr.Tab(\"🔍 Query\"):\n            with gr.Row():\n                with gr.Column(scale=2):\n                    query_input = gr.Textbox(\n                        label=\"Your Question\",\n                        placeholder=\"e.g., Where is dependency injection handled?\",\n                        lines=3\n                    )\n                    use_cache = gr.Checkbox(label=\"Use Cache\", value=True)\n                    use_tools = gr.Checkbox(label=\"Enable Tools\", value=False)\n                    top_k = gr.Slider(3, 20, 10, 1, label=\"Top-K Results\")\n                    submit_btn = gr.Button(\"Analyze\", variant=\"primary\")\n                with gr.Column(scale=1):\n                    gr.Markdown(\"### Example Queries\")\n                    gr.Markdown(\"\"\"\n                    - Where is dependency injection handled?\n                    - How does routing work?\n                    - Explain the middleware system.\n                    - Show me WebSocket implementation.\n                    - What design patterns are used?\n                    \"\"\")\n\n            answer_output = gr.Markdown()\n            with gr.Accordion(\"Retrieved Context\", open=False):\n                citations_output = gr.Dataframe(headers=[\"Source\", \"Lines\", \"Score\", \"Preview\"], wrap=True)\n            metrics_output = gr.Markdown()\n\n            submit_btn.click(\n                fn=analyze_query,\n                inputs=[query_input, use_cache, use_tools, top_k],\n                outputs=[answer_output, citations_output, metrics_output]\n            )\n\n        # ---------------- Repository Selector ----------------\n        with gr.Tab(\"📦 Repository Selector\"):\n            gr.Markdown(\"\"\"\n            ### Select and Reindex a Repository\n            Choose from popular presets or enter a custom GitHub URL.\n            ⚠️ Reindexing large repos may take several minutes.\n            \"\"\")\n\n            preset_dropdown = gr.Dropdown(\n                choices=[\n                    \"FastAPI\", \"Flask\", \"Django\", \"Requests\",\n                    \"NumPy\", \"Pandas\", \"Scikit-learn\", \"LangChain\", \"Custom\"\n                ],\n                value=\"FastAPI\",\n                label=\"Preset Repositories\"\n            )\n            custom_url = gr.Textbox(label=\"Custom GitHub URL\", placeholder=\"https://github.com/user/repo.git\")\n            repo_name_box = gr.Textbox(label=\"Repository Name\", placeholder=\"repo-name\")\n            force_reclone = gr.Checkbox(label=\"Force Re-clone\", value=False)\n            load_btn = gr.Button(\"Load Repository\", variant=\"primary\")\n            status_box = gr.Textbox(label=\"Status\", lines=15, interactive=False)\n\n            load_btn.click(\n                fn=load_repository,\n                inputs=[preset_dropdown, custom_url, repo_name_box, force_reclone],\n                outputs=status_box\n            )\n\n        # ---------------- Tools Tab ----------------\n        with gr.Tab(\"🛠 Tools\"):\n            gr.Markdown(\"### View File\")\n            file_path = gr.Textbox(label=\"File Path\", placeholder=\"e.g., fastapi/routing.py\")\n            start_line = gr.Number(label=\"Start Line\", value=None)\n            end_line = gr.Number(label=\"End Line\", value=None)\n            view_btn = gr.Button(\"View File\")\n            file_output = gr.Code(label=\"File Content\", language=\"python\")\n            view_btn.click(fn=view_file, inputs=[file_path, start_line, end_line], outputs=file_output)\n\n            gr.Markdown(\"### Search Symbol\")\n            symbol_input = gr.Textbox(label=\"Symbol Name\", placeholder=\"e.g., FastAPI, Depends, HTTPException\")\n            search_btn = gr.Button(\"Search\")\n            symbol_output = gr.Textbox(label=\"Results\", lines=10)\n            search_btn.click(fn=search_symbol, inputs=symbol_input, outputs=symbol_output)\n\n        # ---------------- Statistics Tab ----------------\n        with gr.Tab(\"📊 Statistics\"):\n            stats_output = gr.Markdown()\n            refresh_btn = gr.Button(\"Refresh Stats\")\n            refresh_btn.click(fn=show_stats, outputs=stats_output)\n            demo.load(fn=show_stats, outputs=stats_output)\n\n        # ---------------- About Tab ----------------\n        with gr.Tab(\"ℹ️ About\"):\n            gr.Markdown(f\"\"\"\n            ## System Overview\n\n            - **Repository:** {config.repo_name}\n            - **Embedding Model:** {config.embedding_model}\n            - **LLM:** {config.llm_model}\n            - **Chunks:** {len(all_chunks):,}\n            - **Prefix Cache:** {len(llm_engine.prefix_cache)} entries\n\n            ### Architecture\n            1. Ingestion → AST chunking\n            2. Indexing → Dense (VectorStore) + Sparse (TF-IDF)\n            3. Retrieval → Hybrid fusion\n            4. Generation → Long-context LLM with prefix caching\n            5. Tools → File view & symbol search\n            \"\"\")\n\n    return demo\n\n\n# ----------------------------------------------------------------------------\n# To Launch:\n# ----------------------------------------------------------------------------\n# demo = create_gradio_interface()\n# demo.launch(share=True, server_name=\"0.0.0.0\", server_port=7860)\n\n\ndef is_port_in_use(port: int) -> bool:\n    \"\"\"Check if a port is already occupied\"\"\"\n    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:\n        return s.connect_ex((\"localhost\", port)) == 0\n\ndef free_port(port: int = 7860, max_port: int = 7950) -> int:\n    \"\"\"Return a free port in the range [port, max_port]\"\"\"\n    for p in range(port, max_port):\n        if not is_port_in_use(p):\n            return p\n    # fallback random high port\n    return random.randint(8000, 9000)\n\ndef kill_gradio_on_port(port):\n    \"\"\"Safely kill stale Gradio processes using the specified port.\"\"\"\n    for proc in psutil.process_iter(attrs=[\"pid\", \"name\", \"cmdline\"]):\n        try:\n            cmdline = proc.info.get(\"cmdline\") or []\n            if any(str(port) in str(arg) for arg in cmdline):\n                print(f\"⚠️ Killing stale Gradio server (PID {proc.pid}) on port {port}\")\n                proc.kill()\n        except (psutil.NoSuchProcess, psutil.AccessDenied, TypeError):\n            continue\n\n\n# --- Safely release previous port ---\ntarget_port = 7860\nif is_port_in_use(target_port):\n    kill_gradio_on_port(target_port)\n    target_port = free_port(target_port, max_port=7950)\n    print(f\"🔄 Using alternate port: {target_port}\")\n\n# --- Launch Gradio app safely ---\ndemo = create_gradio_interface()\ndemo.launch(\n    share=True,\n    server_name=\"0.0.0.0\",\n    server_port=target_port,\n    quiet=True\n)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:07:39.656050Z","iopub.execute_input":"2025-10-29T02:07:39.656338Z","iopub.status.idle":"2025-10-29T02:07:42.630359Z","shell.execute_reply.started":"2025-10-29T02:07:39.656320Z","shell.execute_reply":"2025-10-29T02:07:42.629551Z"},"id":"jlsbVdkaVX5a","outputId":"032b0a62-ceb9-4f46-b2de-d6d4832d8e41"},"outputs":[{"name":"stdout","text":"🔄 Using alternate port: 7861\nRunning on local URL:  http://0.0.0.0:7861\nIMPORTANT: You are using gradio ve