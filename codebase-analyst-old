lf.use_redis = False\n                self.redis_client = None\n        else:\n            self.redis_client = None\n\n    def _hash_key(self, key: str) -> str:\n        \"\"\"Generate hash for cache key\"\"\"\n        return hashlib.md5(key.encode()).hexdigest()\n\n    def get(self, key: str) -> Optional[Any]:\n        \"\"\"Get from cache\"\"\"\n        hashed_key = self._hash_key(key)\n\n        # Try memory first\n        if hashed_key in self.memory_cache:\n            return self.memory_cache[hashed_key]\n\n        # Try Redis\n        if self.use_redis and self.redis_client:\n            try:\n                value = self.redis_client.get(hashed_key)\n                if value:\n                    deserialized = pickle.loads(value)\n                    # Store in memory\n                    self.memory_cache[hashed_key] = deserialized\n                    return deserialized\n            except Exception as e:\n                print(f\"Redis get error: {e}\")\n\n        return None\n\n    def set(self, key: str, value: Any, ttl: int = 3600):\n        \"\"\"Set in cache\"\"\"\n        hashed_key = self._hash_key(key)\n\n        # Store in memory\n        self.memory_cache[hashed_key] = value\n\n        # Store in Redis\n        if self.use_redis and self.redis_client:\n            try:\n                serialized = pickle.dumps(value)\n                self.redis_client.setex(hashed_key, ttl, serialized)\n            except Exception as e:\n                print(f\"Redis set error: {e}\")\n\n    def clear(self):\n        \"\"\"Clear cache\"\"\"\n        self.memory_cache.clear()\n        if self.use_redis and self.redis_client:\n            self.redis_client.flushdb()\n\n# Initialize cache\ncache_manager = SemanticCache(embedding_engine)#CacheManager(use_redis=config.use_redis)\nprint(\"Cache manager initialized\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:07:27.497311Z","iopub.execute_input":"2025-10-29T02:07:27.497963Z","iopu