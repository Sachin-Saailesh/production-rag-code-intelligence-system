s += 1\n    return hits / max(1, len(top))\n\ndef context_recall(retrieved_paths: List[str], expected_sources: List[str], k: int) -> float:\n    \"\"\"Fraction of expected source patterns that appear in the top-k retrieved.\"\"\"\n    top = retrieved_paths[:k]\n    found = 0\n    for es in expected_sources:\n        if any(es in p for p in top):\n            found += 1\n    return found / max(1, len(expected_sources))\n\ndef answer_faithfulness_lex(answer: str, expected_keywords: Optional[List[str]]) -> float:\n    \"\"\"% of expected keywords found in the answer (lexical heuristic).\"\"\"\n    if not expected_keywords:\n        return np.nan\n    a = answer.lower()\n    hits = sum(1 for kw in expected_keywords if kw.lower() in a)\n    return hits / max(1, len(expected_keywords))\n\ndef context_utilization(answer: str, context_chunks: List[Dict[str, Any]]) -> float:\n    \"\"\"\n    Heuristic: token overlap between answer and concatenated context.\n    Returns Jaccard similarity over unigrams.\n    \"\"\"\n    if not context_chunks:\n        return 0.0\n    ctx = \"\\n\".join(ch[\"payload\"][\"content\"] for ch in context_chunks if \"payload\" in ch and \"content\" in ch[\"payload\"])\n    a_tokens = set(_normalize_text(answer))\n    c_tokens = set(_normalize_text(ctx))\n    if not a_tokens or not c_tokens:\n        return 0.0\n    inter = len(a_tokens & c_tokens)\n    union = len(a_tokens | c_tokens)\n    return inter / max(1, union)\n\n# ---------- Retriever variants ----------\nclass DenseOnlyRetriever:\n    def __init__(self, vector_store, embedding_engine, top_k=10):\n        self.vs = vector_store\n        self.ee = embedding_engine\n        self.top_k = top_k\n    def retrieve(self, query: str, top_k_dense=20, top_k_sparse=0, top_k_final=10):\n        # emulate payload schema used downstream\n        qvec = self.ee.encode([query], batch_size=1, show_progress=False)[0]\n        hits = self.vs.search(qvec, top_k=top_k_final*2)\n        out = []\n        for score, payload in hits[:top_k_final]:\n            out.append({\"score\": float(score), \"payload\": payload})\n        return out\n\nclass SparseOnlyRetriever:\n    def __init__(self, sparse_retriever, top_k=10):\n        self.sparse = sparse_retriever\n        self.top_k = top_k\n    def retrieve(self, query: str, top_k_dense=0, top_k_sparse=20, top_k_final=10):\n        hits = self.sparse.search(query, top_k=top_k_final*2)\n        out = []\n        for score, payload in hits[:top_k_final]:\n            out.append({\"score\": float(score), \"payload\": payload})\n        return out\n\n# ---------- Single run on one item ----------\ndef evaluate_one(\n    analyst, \n    item: EvalItem, \n    top_k_final: int = 10, \n    use_cache: bool = True, \n    use_tools: bool = False\n) -> Dict[str, Any]:\n    t0 = time.time()\n    res = analyst.analyze(item.question, use_cache=use_cache, use_tools=use_tools)\n    latency = time.time() - t0\n\n    # Gather retrieved file paths (if available)\n    retrieved = res.get(\"context\", []) or []\n    paths = []\n    for ctx in retrieved[:top_k_final]:\n        payload = ctx.get(\"payload\", {})\n        paths.append(payload.get(\"file_path\", \"\"))\n\n    # Compute metrics\n    p_at_k = precision_at_k(paths, item.expected_sources, k=min(top_k_final, len(paths) or 1))\n    c_recall = context_recall(paths, item.expected_sources, k=min(top_k_final, len(paths) or 1))\n    faith = answer_faithfulness_lex(res.get(\"answer\", \"\"), item.expected_keywords)\n    util = context_utilization(res.get(\"answer\", \"\"), retrieved)\n\n    return {\n        \"question\": item.question,\n        \"latency\": latency,\n        \"tokens_used\": res.get(\"tokens_used\", np.nan),\n        \"precision_at_k\": p_at_k,\n        \"context_recall\": c_recall,\n        \"answer_faithfulness\": faith,\n        \"context_utilization\": util,\n        \"cache_used\": use_cache,\n    }\n\n# ---------- Suite runner ----------\ndef evaluate_suite(\n    analyst, \n    items: List[EvalItem], \n    top_k_final: int = 10, \n    use_cache: bool = True, \n    use_tools: bool = False\n) -> Tuple[pd.DataFrame, Dict[str, float]]:\n    rows = []\n    for it in items:\n        try:\n            rows.append(evaluate_one(analyst, it, top_k_final, use_cache, use_tools))\n        except Exception as e:\n            rows.append({\n                \"question\": it.question,\n                \"latency\": np.nan,\n                \"tokens_used\": np.nan,\n                \"precision_at_k\": 0.0,\n                \"context_recall\": 0.0,\n                \"answer_faithfulness\": np.nan,\n                \"context_utilization\": 0.0,\n                \"cache_used\": use_cache,\n                \"error\": str(e)\n            })\n    df = pd.DataFrame(rows)\n    summary = {\n        \"n\": len(df),\n        \"avg_latency\": float(np.nanmean(df[\"latency\"])) if len(df) else np.nan,\n        \"p95_latency\": float(np.nanpercentile(df[\"latency\"], 95)) if len(df) else np.nan,\n        \"avg_tokens\": float(np.nanmean(df[\"tokens_used\"])) if len(df) else np.nan,\n        \"precision_at_k\": float(np.nanmean(df[\"precision_at_k\"])) if len(df) else np.nan,\n        \"context_recall\": float(np.nanmean(df[\"context_recall\"])) if len(df) else np.nan,\n        \"answer_faithfulness\": float(np.nanmean(df[\"answer_faithfulness\"])) if len(df) else np.nan,\n        \"context_utilization\": float(np.nanmean(df[\"context_utilization\"])) if len(df) else np.nan,\n        \"cache_used\": use_cache,\n    }\n    return df, summary\n\n# ---------- Variant benchmark (cache on/off, retriever modes) ----------\ndef run_benchmarks(\n    analyst,\n    items: List[EvalItem],\n    top_k_final: int = 10,\n    include_dense_sparse_variants: bool = True,\n    vector_store=None,\n    sparse_retriever=None,\n    embedding_engine=None,\n):\n    results = []\n    details = {}\n\n    # Keep original retriever to restore later\n    orig_retriever = analyst.retriever\n\n    # 1) Hybrid, Cache OFF\n    analyst.retriever = orig_retriever\n    df1, s1 = evaluate_suite(analyst, items, top_k_final, use_cache=False)\n    s1[\"variant\"] = \"hybrid_cache_off\"\n    results.append(s1); details[\"hybrid_cache_off\"] = df1\n\n    # 2) Hybrid, Cache ON\n    df2, s2 = evaluate_suite(analyst, items, top_k_final, use_cache=True)\n    s2[\"variant\"] = \"hybrid_cache_on\"\n    results.append(s2); details[\"hybrid_cache_on\"] = df2\n\n    if include_dense_sparse_variants and vector_store and sparse_retriever and embedding_engine:\n        # 3) Dense only\n        analyst.retriever = DenseOnlyRetriever(vector_store, embedding_engine, top_k=top_k_final)\n        df3, s3 = evaluate_suite(analyst, items, top_k_final, use_cache=False)\n        s3[\"variant\"] = \"dense_only\"\n        results.append(s3); details[\"dense_only\"] = df3\n\n        # 4) Sparse only\n        analyst.retriever = SparseOnlyRetriever(sparse_retriever, top_k=top_k_final)\n        df4, s4 = evaluate_suite(analyst, items, top_k_final, use_cache=False)\n        s4[\"variant\"] = \"sparse_only\"\n        results.append(s4); details[\"sparse_only\"] = df4\n\n    # Restore original\n    analyst.retriever = orig_retriever\n\n    summary_df = pd.DataFrame(results)[[\n        \"variant\", \"n\", \"avg_latency\", \"p95_latency\",\n        \"avg_tokens\", \"precision_at_k\", \"context_recall\",\n        \"answer_faithfulness\", \"context_utilization\", \"cache_used\"\n    ]].sort_values(\"variant\")\n\n    return summary_df, details\n\n# ---------- Usage ----------\nsummary, details = run_benchmarks(\n    analyst=analyst,\n    items=EVAL_SET,             # replace with your own eval set\n    top_k_final=10,\n    include_dense_sparse_variants=True,\n    vector_store=vector_store,\n    sparse_retriever=sparse_retriever,\n    embedding_engine=embedding_engine\n)\nprint(summary.to_markdown(index=False))\nsummary.to_csv(\"evaluation_summary.csv\", index=False)\nfor name, df in details.items():\n    df.to_csv(f\"evaluation_detail_{name}.csv\", index=False)\n\nimport matplotlib.pyplot as plt\nplt.bar(summary[\"variant\"], summary[\"avg_latency\"])\nplt.title(\"Average Latency by Variant\")\nplt.ylabel(\"Seconds\"); plt.xticks(rotation=45)\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:51:11.692333Z","iopub.execute_input":"2025-10-29T02:51:11.692811Z","iopub.status.idle":"2025-10-29T02:51:30.221604Z","shell.execute_reply.started":"2025-10-29T02:51:11.692787Z","shell.execute_reply":"2025-10-29T02:51:30.220847Z"}},"outputs":[{"name":"stdout","text":"Retrieving context for: Where is dependency injection handled?\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Batches:   0%|          | 0/1 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"8847982e51114ed19a5ffe3d8cc33b9a"}},"metadata":{}},{"name":"stdout","text":"Generating response...\n📊 Prefix: 4530 tokens (cached) | Query: 6 | Total: 4536\nRetrieving context for: Explain the middleware system in FastAPI.\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Batches:   0%|          | 0/1 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"3a6d5ea5768e41288a7965475bb12867"}},"metadata":{}},{"name":"stdout","text":"Generating response...\n📊 Prefix: 3906 tokens (cached) | Query: 9 | Total: 3915\nRetrieving context for: How is routing implemented?\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Batches:   0%|          | 0/1 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"e09e73d2e4a24b5aa21ec950794fdbb9"}},"metadata":{}},{"name":"stdout","text":"Generating response...\n📊 Prefix: 5358 tokens (cached) | Query: 5 | Total: 5363\n🧠 Semantic cache HIT (sim=1.000)\n🧠 Cache HIT (exact key)\n🧠 Semantic cache HIT (sim=1.000)\