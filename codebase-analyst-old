 cache_hit_counter.inc()\n\n    def record_cache_miss(self):\n        \"\"\"Record cache miss\"\"\"\n        self.cache_stats['misses'] += 1\n        cache_miss_counter.inc()\n\n    def get_stats(self) -> dict:\n        \"\"\"Get performance statistics\"\"\"\n        if not self.query_times:\n            return {}\n\n        return {\n            'total_queries': len(self.query_times),\n            'avg_latency': np.mean(self.query_times),\n            'p50_latency': np.percentile(self.query_times, 50),\n            'p95_latency': np.percentile(self.query_times, 95),\n            'p99_latency': np.percentile(self.query_times, 99),\n            'avg_tokens': np.mean(self.token_usage),\n            'total_tokens': sum(self.token_usage),\n            'cache_hit_rate': (\n                self.cache_stats['hits'] /\n                (self.cache_stats['hits'] + self.cache_stats['misses'])\n                if (self.cache_stats['hits'] + self.cache_stats['misses']) > 0 else 0\n            ),\n            'memory_usage_mb': psutil.Process().memory_info().rss / 1024 / 1024\n        }\n\n    def print_stats(self):\n        \"\"\"Print formatted statistics\"\"\"\n        stats = self.get_stats()\n        if not stats:\n            print(\"No statistics available yet\")\n            return\n\n        print(\"\\n\" + \"=\"*60)\n        print(\"PERFORMANCE METRICS\")\n        print(\"=\"*60)\n        print(f\"Total Queries:      {stats['total_queries']}\")\n        print(f\"Avg Latency:        {stats['avg_latency']:.2f}s\")\n        print(f\"P95 Latency:        {stats['p95_latency']:.2f}s\")\n        print(f\"P99 Latency:        {stats['p99_latency']:.2f}s\")\n        print(f\"Avg Tokens/Query:   {stats['avg_tokens']:.0f}\")\n        print(f\"Total Tokens:       {stats['total_tokens']:.0f}\")\n        print(f\"Cache Hit Rate:     {stats['cache_hit_rate']:.1%}\")\n        print(f\"Memory Usage:       {stats['memory_usage_mb']:.0f} MB\")\n        print(\"=\"*60 + \"\\n\")\n\n# Initia