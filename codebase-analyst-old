fig: Config):\n        self.config = config\n        self.parser = CodeParser()\n\n    def clone_repository(self, url: str, target_dir: Path) -> Path:\n        \"\"\"Clone git repository\"\"\"\n        if target_dir.exists():\n            print(f\"Repository already exists at {target_dir}\")\n            return target_dir\n\n        print(f\"Cloning repository from {url}...\")\n        git.Repo.clone_from(url, target_dir, depth=1)\n        print(f\"Repository cloned to {target_dir}\")\n        return target_dir\n\n    def scan_repository(self, repo_dir: Path) -> List[Path]:\n        \"\"\"Scan repository for code files\"\"\"\n        code_files = []\n\n        for ext in self.parser.supported_extensions.keys():\n            code_files.extend(repo_dir.rglob(f\"*{ext}\"))\n\n        # Filter out common non-source directories\n        exclude_dirs = {'.git', 'node_modules', '__pycache__', '.pytest_cache',\n                       'venv', 'env', 'build', 'dist', '.tox'}\n\n        filtered_files = []\n        for f in code_files:\n            if not any(excluded in f.parts for excluded in exclude_dirs):\n                filtered_files.append(f)\n\n        print(f\"Found {len(filtered_files)} code files\")\n        return filtered_files\n\n    def process_files(self, files: List[Path]) -> List[Dict[str, Any]]:\n        \"\"\"Parse all files\"\"\"\n        parsed_files = []\n\n        for file_path in tqdm(files, desc=\"Parsing files\"):\n            parsed = self.parser.parse_file(file_path)\n            if parsed:\n                parsed_files.append(parsed)\n\n        print(f\"Parsed {len(parsed_files)} files successfully\")\n        return parsed_files\n\n    def chunk_document(self, doc: Dict[str, Any]) -> List[Dict[str, Any]]:\n        \"\"\"Chunk a document into smaller pieces\"\"\"\n        chunks = []\n        content = doc['content']\n        lines = content.split('\\n')\n\n        # Create chunks with overlap\n        current_chunk = []\n        current_size = 0\n        chunk_id = 0\n\n        for i, line in enumerate(lines, 1):\n            line_tokens = len(line.split())\n\n            if current_size + line_tokens > config.chunk_size and current_chunk:\n                # Save current chunk\n                chunk_text = '\\n'.join(current_chunk)\n                chunks.append({\n                    'chunk_id': f\"{doc['file_path']}::{chunk_id}\",\n                    'file_path': doc['file_path'],\n                    'language': doc['language'],\n                    'content': chunk_text,\n                    'start_line': i - len(current_chunk),\n                    'end_line': i,\n                    'functions': [f for f in doc['functions']\n                                if i - len(current_chunk) <= f['lineno'] <= i],\n                    'classes': [c for c in doc['classes']\n                              if i - len(current_chunk) <= c['lineno'] <= i],\n                })\n                chunk_id += 1\n\n                # Keep overlap\n                overlap_lines = int(len(current_chunk) * config.chunk_overlap / config.chunk_size)\n                current_chunk = current_chunk[-overlap_lines:]\n                current_size = sum(len(l.split()) for l in current_chunk)\n\n            current_chunk.append(line)\n            current_size += line_tokens\n\n        # Add final chunk\n        if current_chunk:\n            chunk_text = '\\n'.join(current_chunk)\n            chunks.append({\n                'chunk_id': f\"{doc['file_path']}::{chunk_id}\",\n                'file_path': doc['file_path'],\n                'language': doc['language'],\n                'content': chunk_text,\n                'start_line': len(lines) - len(current_chunk) + 1,\n                'end_line': len(lines),\n                'functions': [f for f in doc['functions']\n                            if len(lines) - len(current_chunk) <= f['lineno'] <= len(lines)],\n                'classes': [c for c in doc['classes']\n                          if len(lines) - len(current_chunk) <= c['lineno'] <= len(lines)],\n            })\n\n        return chunks\n\n# Initialize ingester\ningester = RepositoryIngester(config)\n\n# Clone and process repository\nrepo_dir = config.data_dir / config.repo_name\nrepo_dir = ingester.clone_repository(config.repo_url, repo_dir)\n\n# Scan and parse files\ncode_files = ingester.scan_repository(repo_dir)\nparsed_docs = ingester.process_files(code_files)\n\n# Create chunks\nall_chunks = []\nfor doc in tqdm(parsed_docs, desc=\"Chunking documents\"):\n    chunks = ingester.chunk_document(doc)\n    all_chunks.extend(chunks)\n\nprint(f\"Created {len(all_chunks)} chunks from {len(parsed_docs)} files\")\n\n# Save processed data\nwith open(config.cache_dir / \"chunks.pkl\", \"wb\") as f:\n    pickle.dump(all_chunks, f)\n\nprint(f\"Saved chunks to {config.cache_dir / 'chunks.pkl'}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:05:43.294308Z","iopub.execute_input":"2025-10-29T02:05:43.294518Z","iopub.status.idle":"2025-10-29T02:05:44.197924Z","shell.execute_reply.started":"2025-10-29T02:05:43.294503Z","shell.execute_reply":"2025-10-29T02:05:44.197037Z"},"id":"8OKn1x6nVX5U","outputId":"c402b756-7f6b-4647-baff-50df2efe40a2"},"outputs":[{"name":"stdout","text":"Repository already exists at /kaggle/working/data/fastapi\nFound 1178 code files\n","output_type":"stream"},{"name":"stderr","text":"Parsing files: 100%|██████████| 1178/1178 [00:00<00:00, 1619.68it/s]\n","output_type":"stream"},{"name":"stdout","text":"Parsed 1178 files successfully\n","output_type":"stream"},{"name":"stderr","text":"Chunking documents: 100%|██████████| 1178/1178 [00:00<00:00, 25428.66it/s]","output_type":"stream"},{"name":"stdout","text":"Created 1470 chunks from 1178 files\nSaved chunks to /kaggle/working/cache/chunks.pkl\n","output_type":"stream"},{"name":"stderr","text":"\n","output_type":"stream"}],"execution_count":32},{"cell_type":"code","source":"#Embedding Model & Vector Indexing\n# --- Compatibility shim: allow newer Pooling configs on older sentence-transformers ---\nfrom sentence_transformers.models import Pooling as _Pooling\nimport inspect, json, os\nfrom typing import List\nimport numpy as np\nfrom sentence_transformers import SentenceTransformer\nimport torch\n\nif \"include_prompt\" not in inspect.signature(_Pooling.__init__).parameters:\n    def _patched_pooling_load(input_path: str):\n        with open(os.path.join(input_path, \"config.json\"), \"r\") as f:\n            cfg = json.load(f)\n        allowed = set(inspect.signature(_Pooling.__init__).parameters.keys()) - {\"self\"}\n        cfg = {k: v for k, v in cfg.items() if k in allowed}\n        return _Pooling(**cfg)\n    _Pooling.load = staticmethod(_patched_pooling_load)\n\n\nclass EmbeddingEngine:\n    \"\"\"Generate embeddings using sentence transformers\"\"\"\n\n    def __init__(self, model_name: str, use_gpu: bool = True):\n        gpu_ok = bool(use_gpu) and torch.cuda.is_available()\n        device = \"cuda\" if gpu_ok else \"cpu\"\n        if use_gpu and not gpu_ok:\n            print(\"GPU requested but not available; falling back to CPU.\")\n        print(f\"Loading embedding model: {model_name} on {device}\")\n        self.model = SentenceTransformer(model_name, device=device)\n        self.dimension = self.model.get_sentence_embedding_dimension()\n        print(f\"Embedding dimension: {self.dimension}\")\n\n    def encode(self, texts: List[str], batch_size: int = 32, show_progress: bool = True) -> np.ndarray:\n        return self.model.encode(\n            texts,\n            batch_size=batch_size,\n            show_progress_bar=show_progress,\n            convert_to_numpy=True,\n            normalize_embeddings=True,\n        )\n\n    def encode_query(self, query: str) -> np.ndarray:\n        return self.model.encode([query], convert_to_numpy=True, normalize_embeddings=True)[0]\n\n# Initialize embedding model\nembedding_engine = EmbeddingEngine(config.embedding_model, config.use_gpu)\n\n# Generate embeddings for chunks\nprint(\"Generating embeddings for all chunks...\")\nchunk_texts = [\n    f\"{chunk['file_path']}\\n{chunk['content']}\"\n    for chunk in all_chunks\n]\n\nembeddings = embedding_engine.encode(\n    chunk_texts,\n    batch_size=config.batch_size,\n    show_progress=True\n)\n\nprint(f\"Generated {embeddings.shape[0]} embeddings of dimension {embeddings.shape[1]}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:05:44.198861Z","iopub.execute_input":"2025-10-29T02:05:44.199168Z","iopub.status.idle":"2025-10-29T02:07:16.571340Z","shell.execute_reply.started":"2025-10-29T02:05:44.199125Z","shell.execute_reply":"2025-10-29T02:07:16.570661Z"},"id":"hwVqkpx0VX5V","outputId":"528a47ec-f621-4a38-e7cc-520afc68ce85","colab":{"referenced_widgets":["7262cead18b94b13bc00a742fca5ab1f","5ecb5dab89c340a9804e423eab40182c","69cec993649c418fb976052995bb7be2","3b36ccf23b604c11ad48ca78f6a5f0ad","ee2d3f42ab65442c8bf8964da87bb78b","d91a517b596a433ca97ce72cc34eae65","85f1ca01d7a64f289bdf217120ce1b9b","308a46b64dcf49a7b2e48232de0c276b","209d5d2909bd46f3819a871f0616af0b","ded3f4ddf3f847daa94b7e9d5dc9d1ea","acecf2e14539491e934c538fbab32a88","772484f002f14dc4a2ab0ddda65d5a8f"]}},"outputs":[{"name":"stdout","text":"Loading embedding model: mixedbread-ai/mxbai-embed-large-v1 on cuda\nEmbedding dimension: 1024\nGenerating embeddings for all chunks...\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Batches:   0%|          | 0/46 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"ea83cfeb0e244e658fb73296cbb894a3"}},"metadata":{}},{"name":"stdout","text":"Generated 1470 embeddings of dimension 1024\n","output_type":"stream"}],"execution_count":33},{"cell_type":"code","source":"#Qdrant Vector Store Setup\n\nclass VectorStore:\n    \"\"\"Qdrant vector database wrapper\"\"\"\n\n    def __init__(self, collection_name: str, dimension: int,\n                 path: Optional[Path] = None):\n        self.collection_name = collection_name\n        self.dimension = dimension\n\n        # in-memory for Kaggle\n        if path:\n            self.client = QdrantClient(path=str(path))\n        else:\n            self.client = QdrantClient(\":memory:\")\n\n        self._create_collection()\n\n    def _create_collection(self):\n        \"\"\"Create or recreate collection\"\"\"\n        collections = self.client.get_collections().collections\n        collection_names = [c.name for c in collections]\n\n        if self.collection_name in collection_names:\n            self.client.delete_collection(self.collection_name)\n\n        self.client.create_collection(\n            collection_name=self.collection_name,\n            vectors_config=VectorParams(\n                size=self.dimension,\n                distance=Distance.COSINE\n            )\n        )\n        print(f\"Created collection: {self.collection_name}\")\n\n    def add_vectors(self, vectors: np.ndarray, payloads: List[Dict[str, Any]],\n                   batch_size: int = 100):\n        \"\"\"Add vectors to collection\"\"\"\n        points = []\n\n        for i, (vector, payload) in enumerate(zip(vectors, payloads)):\n            points.append(PointStruct(\n                id=i,\n                vector=vector.tolist(),\n                payload=payload\n            ))\n\n            if len(points) >= batch_size:\n                self.client.upsert(\n                    collection_name=self.collection_name,\n                    points=points\n                )\n                points = []\n\n        if points:\n            self.client.upsert(\n                collection_name=self.collection_name,\n                points=points\n            )\n\n        print(f\"Added {len(vectors)} vectors to collection\")\n\n    def search(self, query_vector: np.ndarray, top_k: int = 10) -> List[Dict]:\n        \"\"\"Search for similar vectors\"\"\"\n        results = self.client.search(\n            collection_name=self.collection_name,\n            query_vector=query_vector.tolist(),\n            limit=top_k\n        )\n\n        return [\n            {\n                'id': hit.id,\n                'score': hit.score,\n                'payload': hit.payload\n            }\n            for hit in results\n        ]\n\nimport shutil, os\n\n# --- Patch: Clear existing Qdrant local lock before new init ---\nqdrant_path = Path(config.index_dir)\nlock_file = qdrant_path / \".flock\"\nif lock_file.exists():\n    print(f\"⚠️ Removing stale Qdrant lock: {lock_file}\")\n    try:\n        lock_file.unlink()\n    except Exception as e:\n        print(f\"Could not remove lock: {e}\")\n\n# Optional safety: if reindexing, remove the old folder entirely\nif any(qdrant_path.iterdir()):\n    print(\"🧹 Clearing Qdrant index directory for fresh init...\")\n    shutil.rmtree(qdrant_path, ignore_errors=True)\n    qdrant_path.mkdir(parents=True, exist_ok=True)\n\n\n# Initialize vector store\nvector_store = VectorStore(\n    collection_name=\"codebase\",\n    dimension=embedding_engine.dimension,\n    path=config.index_dir\n)\n\n# Add embeddings\npayloads = [\n    {\n        'chunk_id': chunk['chunk_id'],\n        'file_path': chunk['file_path'],\n        'language': chunk['language'],\n        'content': chunk['content'],\n        'start_line': chunk['start_line'],\n        'end_line': chunk['end_line'],\n        'functions': [f['name'] for f in chunk['functions']],\n        'classes': [c['name'] for c in chunk['classes']],\n    }\n    for chunk in all_chunks\n]\n\nvector_store.add_vectors(embeddings, payloads, batch_size=100)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:07:16.572071Z","iopub.execute_input":"2025-10-29T02:07:16.572290Z","iopub.status.idle":"2025-10-29T02:07:25.287406Z","shell.execute_reply.started":"2025-10-29T02:07:16.572267Z","shell.execute_reply":"2025-10-29T02:07:25.286577Z"},"id":"XZPhHoR3VX5V","outputId":"baaf4d52-fbbb-4ec5-89fc-11d30b3ecadb"},"outputs":[{"name":"stdout","text":"🧹 Clearing Qdrant index directory for fresh init...\nCreated collection: codebase\nAdded 1470 vectors to collection\n","output_type":"stream"}],"execution_count":34},{"cell_type":"code","source":"#BM25 Sparse Retrieval\n\nclass SparseRetriever:\n    \"\"\"BM25 keyword-based retrieval\"\"\"\n\n    def __init__(self):\n        self.bm25 = None\n        self.corpus = []\n        self.metadata = []\n\n    def index(self, documents: List[Dict[str, Any]]):\n        \"\"\"Index documents for BM25\"\"\"\n        self.corpus = []\n        self.metadata = []\n\n        for doc in documents:\n            # Tokenize for BM25\n            text = f\"{doc['file_path']} {doc['content']}\"\n            tokens = self._tokenize(text)\n            self.corpus.append(tokens)\n            self.metadata.append(doc)\n\n        self.bm25 = BM25Okapi(self.corpus)\n        print(f\"Indexed {len(self.corpus)} documents for BM25\")\n\n    def _tokenize(self, text: str) -> List[str]:\n        \"\"\"Simple tokenization\"\"\"\n        # Split on non-alphanumeric and keep underscores\n        tokens = re.findall(r'\\w+', text.lower())\n        return tokens\n\n    def search(self, query: str, top_k: int = 10) -> List[Dict]:\n        \"\"\"Search using BM25\"\"\"\n        query_tokens = self._tokenize(query)\n        scores = self.bm25.get_scores(query_tokens)\n\n        # Get top-k indices\n        top_indices = np.argsort(scores)[-top_k:][::-1]\n\n        results = []\n        for idx in top_indices:\n            if scores[idx] > 0:\n                results.append({\n                    'score': float(scores[idx]),\n                    'payload': self.metadata[idx]\n                })\n\n        return results\n\n# Initialize BM25\nsparse_retriever = SparseRetriever()\nsparse_retriever.index(all_chunks)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:07:25.289315Z","iop