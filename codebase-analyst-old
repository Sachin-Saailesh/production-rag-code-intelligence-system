ge of ground truth words\n        gt_words = set(ground_truth.lower().split())\n        covered_words = sum(1 for word in gt_words if word in all_content)\n\n        return covered_words / len(gt_words) if gt_words else 0.0\n\n    def faithfulness(self, answer: str, contexts: List[Dict]) -> float:\n        \"\"\"Measure if answer is grounded in retrieved contexts\"\"\"\n        if not contexts:\n            return 0.0\n\n        # Simple check: answer claims should appear in contexts\n        answer_sentences = answer.split('.')\n        all_content = ' '.join([\n            ctx['payload']['content'].lower()\n            for ctx in contexts\n        ])\n\n        faithful_count = 0\n        for sentence in answer_sentences:\n            sentence = sentence.strip().lower()\n            if not sentence:\n                continue\n            # Check if key phrases from answer appear in contexts\n            words = sentence.split()\n            if len(words) > 3:\n                key_phrase = ' '.join(words[:3])\n                if key_phrase in all_content:\n                    faithful_count += 1\n\n        return faithful_count / len(answer_sentences) if answer_sentences else 0.0\n\n    def answer_relevancy(self, query: str, answer: str) -> float:\n        \"\"\"Measure if answer addresses the query\"\"\"\n        query_words = set(query.lower().split())\n        answer_words = set(answer.lower().split())\n\n        overlap = query_words.intersection(answer_words)\n        return len(overlap) / len(query_words) if query_words else 0.0\n\n    def evaluate_query(self, query: str, ground_truth: Optional[str] = None) -> Dict[str, Any]:\n        \"\"\"Evaluate a single query\"\"\"\n        # Run query\n        result = self.analyst.analyze(query, use_cache=True)\n\n        # Calculate metrics\n        metrics = {\n            'query': query,\n            'latency': result['latency'],\n            'tokens_used': result['tokens_used'],\n            'num_contexts': len(result['context']),\n        }\n\n        if ground_truth:\n            metrics['context_precision'] = self.context_precision(\n                result['context'], ground_truth\n            )\n            metrics['context_recall'] = self.context_recall(\n                result['context'], ground_truth\n            )\n            metrics['faithfulness'] = self.faithfulness(\n                result['answer'], result['context']\n            )\n\n        metrics['answer_relevancy'] = self.answer_relevancy(\n            query, result['answer']\n        )\n\n        self.eval_results.append(metrics)\n        return metrics\n\n    def evaluate_batch(self, test_queries: List[Dict[str, str]]) -> pd.DataFrame:\n        \"\"\"Evaluate multiple queries\"\"\"\n        results = []\n\n        for item in tqdm(test_queries, desc=\"Evaluating\"):\n            query = item['query']\n            ground_truth = item.get('ground_truth')\n\n            metrics = self.evaluate_query(query, ground_truth)\n            results.append(metrics)\n\n        return pd.DataFrame(results)\n\n    def get_summary(self) -> Dict[str, float]:\n        \"\"\"Get summary statistics\"\"\"\n        if not self.eval_results:\n            return {}\n\n        df = pd.DataFrame(self.eval_results)\n\n        summary = {\n            'avg_latency': df['latency'].mean(),\n            'avg_tokens': df['tokens_used'].mean(),\n            'avg_contexts': df['num_contexts'].mean(),\n        }\n\n        if 'context_precision' in df.columns:\n            summary['avg_context_precision'] = df['context_precision'].mean()\n        if 'context_recall' in df.columns:\n            summary['avg_context_recall'] = df['context_recall'].mean()\n        if 'faithfulness' in df.columns:\n            summary['avg_faithfulness'] = df['faithfulness'].mean()\n        if 'answer_relevancy' in df.columns:\n            summary['avg_answer_relevancy'] = df['answer_relevancy'].mean()\n\n        return summary\n\n# Initialize evaluator\nevalu