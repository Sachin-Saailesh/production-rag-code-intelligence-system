           \"file_path\": {\"type\": \"string\", \"description\": \"File containing the symbol (optional)\"}\n                },\n                \"required\": [\"symbol\"]\n            }\n        }\n    }\n]\n\n# -----------------------------\n# Cached prefix dataclass\n# -----------------------------\n@dataclass\nclass CachedPrefix:\n    system_prompt: str\n    context_instruction: str\n    cached_chunks: List[Dict]\n    prefix_hash: str\n    token_count: int\n\n\n# ======================================================\n# ✅ FUSED ENGINE: combines old LLMEngine + Claude version\n# ======================================================\nclass LLMEngine:\n    \"\"\"Unified LLM Engine with tool support and deterministic prefix caching\"\"\"\n\n    def __init__(self, provider: str = \"openai\", model: str = \"gpt-4o-mini\",\n             api_key: Optional[str] = None):\n        \"\"\"Initialize LLM engine with correct API handling for OpenAI/DeepSeek.\"\"\"\n        import os\n        import openai\n        import tiktoken\n    \n        self.provider = provider.lower()\n        self.model = model\n        self.api_key = api_key or os.getenv(\"OPENAI_API_KEY\") or os.getenv(\"DEEPSEEK_API_KEY\")\n    \n        if not self.api_key:\n            raise ValueError(\"❌ No API key found. Please set OPENAI_API_KEY or pass api_key argument.\")\n    \n        # ✅ Correct initialization — do NOT use openai.OpenAI()\n        if self.provider == \"openai\":\n            openai.api_key = self.api_key\n            self.client = openai\n        elif self.provider == \"deepseek\":\n            # DeepSeek uses the same OpenAI-compatible SDK endpoint\n            import openai as deepseek\n            deepseek.api_key = self.api_key\n            self.client = deepseek\n        else:\n            raise ValueError(f\"Unknown provider: {provider}\")\n    \n        # ✅ Tokenizer\n        self.tokenizer = tiktoken.encoding_for_model(\"gpt-4\")\n    \n        # ✅ Cache + system prompt setup\n        self.prefix_cache: Dict[str, CachedPrefix] = {}\n        self.stable_system_prompt = self._get_system_prompt()\n        self.context_instruction = (\n            \"Below is relevant code from the codebase. Use this context to answer the question that follows.\\n\\n\"\n            \"---CONTEXT START---\"\n        )\n\n\n    # --------------------------\n    # TOKEN & CONTEXT UTILITIES\n    # --------------------------\n    def count_tokens(self, text: str) -> int:\n        return len(self.tokenizer.encode(text))\n\n    def _get_system_prompt(self) -> str:\n        \"\"\"System prompt kept stable for cache hits\"\"\"\n        return \"\"\"You are an expert code analyst. Your task is to answer questions about codebases using the provided context.\n\nGuidelines:\n1. Always cite specific files and line numbers when referencing code\n2. Explain complex concepts clearly\n3. Point out architectural patterns and design decisions\n4. If the context doesn't contain enough information, say so\n5. Use technical terminology appropriately\n6. Format code snippets with proper syntax highlighting\n\nWhen citing, use format: `file_path:line_number`\"\"\"\n\n    def _format_context_deterministic(self, context: List[Dict]) -> str:\n        \"\"\"Stable context ordering for cache reuse\"\"\"\n        sorted_context = sorted(context, key=lambda x: x['payload'].get('chunk_id', x['payload']['file_path']))\n        formatted = []\n        for i, item in enumerate(sorted_context, 1):\n            p = item['payload']\n            formatted.append(\n                f\"[{i}] {p['file_path']} (lines {p['start_line']}-{p['end_line']})\\n\"\n                f\"```{p['language']}\\n{p['content']}\\n```\"\n            )\n        return \"\\n\\n\".join(formatted)\n\n    # --------------------------\n    # CACHE MANAGEMENT\n    # --------------------------\n    def _compute_prefix_hash(self, context: List[Dict]) -> str:\n        chunk_ids = sorted([c['payload'].get('chunk_id', c['payload']['file_path']) for c in context])\n        hash_input = json.dumps(chunk_ids, sort_keys=True)\n        return hashlib.md5(hash_input.encode()).hexdigest()\n\n    def _build_cached_prefix(self, context: List[Dict]) -> tuple[List[Dict], str]:\n        prefix_hash = self._compute_prefix_hash(context)\n        if prefix_hash in self.prefix_cache:\n            cached = self.prefix_cache[prefix_hash]\n            context_text = self._format_context_deterministic(cached.cached_chunks)\n        else:\n            context_text = self._format_context_deterministic(context)\n            self.prefix_cache[prefix_hash] = CachedPrefix(\n                system_prompt=self.stable_system_prompt,\n                context_instruction=self.context_instruction,\n                cached_chunks=context,\n                prefix_hash=prefix_hash,\n                token_count=self.count_tokens(self.stable_system_prompt + context_text)\n            )\n\n        prefix_messages = [\n            {\"role\": \"system\", \"content\": self.stable_system_prompt},\n            {\"role\": \"user\", \"content\": f\"{self.context_instruction}\\n\\n{context_text}\\n\\n---CONTEXT END---\"},\n            {\"role\": \"assistant\", \"content\": \"Context analyzed. Ready for your question.\"}\n        ]\n        return prefix_messages, prefix_hash\n\n    def clear_cache(self):\n        self.prefix_cache.clear()\n        print(\"🧹 Prefix cache cleared.\")\n\n    def get_cache_stats(self) -> Dict[str, Any]:\n        return {\n            \"cached_prefixes\": len(self.prefix_cache),\n            \"total_prefix_tokens\": sum(p.token_count for p in self.prefix_cache.values())\n        }\n\n    # --------------------------\n    # GENERATION WITH TOOL CALLS\n    # --------------------------\n    def generate(self, prompt: str, context: List[Dict],\n                 max_tokens: int = 4096, temperature: float = 0.1,\n                 tools: Optional[List[Dict]] = None) -> Dict[str, Any]:\n\n        prefix_messages, context_hash = self._build_cached_prefix(context)\n        messages = prefix_messages + [{\"role\": \"user\", \"content\": prompt}]\n\n        prefix_tokens = self.prefix_cache[context_hash].token_count\n        query_tokens = self.count_tokens(prompt)\n        total_tokens = prefix_tokens + query_tokens\n        print(f\"📊 Prefix: {prefix_tokens} tokens (cached) | Query: {query_tokens} | Total: {total_tokens}\")\n\n        try:\n            if self.client is None:\n                raise RuntimeError(\"OpenAI client not initialized properly. Check API key and SDK version.\")\n        \n            # ✅ Correct OpenAI SDK usage (for latest API)\n            response = self.client.chat.completions.create(\n                model=self.model,\n                messages=messages,\n                max_tokens=max_tokens,\n                temperature=temperature,\n                tools=tools if tools else None\n            )\n        \n            return {\n                \"content\": response.choices[0].message.content,\n                \"tool_calls\": getattr(response.choices[0].message, \"tool_calls\", None),\n                \"tokens_used\": getattr(response.usage, \"total_tokens\", 0),\n            }\n        \n        except Exception as e:\n            # ❌ Remove mock fallback\n            raise RuntimeError(f\"LLM API call failed: {e}\")\n\n\n    # --------------------------\n    # MOCK FALLBACK\n    # --------------------------\n    def _mock_response(self, prompt: str, context: List[Dict]) -> Dict[str, Any]:\n        files = [c['payload']['file_path'] for c in context[:3]]\n        mock_content = f\"\"\"Based on the codebase analysis, here's what I found:\n\nThe code related to \"{prompt}\" is primarily located in:\n1. {files[0] if files else 'N/A'} — lines {context[0]['payload']['start_line']}-{context[0]['payload']['end_line']}.\n\nThe implementation follows standard modular and typed Python design.\n\n(Mocked due to missing API key)\"\"\"\n\n        return {\n            'content': mock_content,\n            'tool_calls': None,\n            'tokens_used': self.count_tokens(mock_content),\n            'prefix_hash': 'mock'\n        }\n\n# Example initialization\n# OPENAI_API_KEY = \"sk-...\"\nllm_engine = LLMEngine(provider=\"openai\", model=\"gpt-4o-mini\", api_key=OPENAI_API_KEY)\nprint(\"✅ LLM Engine with deterministic caching initialized.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:07:26.072524Z","iopub.execute_input":"2025-10-29T02:07:26.072750Z","iopub.status.idle":"2025-10-29T02:07:26.099011Z","shell.execute_reply.started":"2025-10-29T02:07:26.072726Z","shell.execute_reply":"2025-10-29T02:07:26.098202Z"},"id":"q4w83Zz0VX5X","outputId":"295d9788-76ce-4b1c-d62d-15679a492624"},"outputs":[{"name":"stdout","text":"✅ LLM Engine with deterministic caching initialized.\n","output_type":"stream"}],"execution_count":38},{"cell_type":"code","source":"from openai import OpenAI\n\ndef sanity_check_openai_model(model: str, api_key: Optional[str] = None) -> bool:\n    \"\"\"Returns True if the model is reachable & can answer a 1-token prompt.\"\"\"\n    api_key = OPENAI_API_KEY\n    if not api_key:\n        print(\"✗ No OPENAI_API_KEY found (env or Kaggle Secrets).\")\n        return False\n\n    client = OpenAI(api_key=api_key)\n    ok = True\n\n    # 1) tiktoken encoding load (helps catch typos/unknown model family)\n    try:\n        enc = tiktoken.encoding_for_model(model)\n        print(f\"✓ tiktoken encoding loaded for {model}: {enc.name}\")\n    except Exception as e:\n        print(f\"⚠ tiktoken couldn't find encoding for {model}: {e} (will still try API)\")\n        ok = False  # not fatal, just signal mismatch\n\n    # 2) models.retrieve() (fast, no tokens billed)\n    try:\n        m = client.models.retrieve(model)\n        print(f\"✓ models.retrieve OK: {m.id}\")\n    except Exception as e:\n        print(f\"⚠ models.retrieve failed: {e} (alias or permission?)\")\n        # not fatal—some aliases may not list; the chat call below is the source of truth\n\n    # 3) 1-token chat completion (definitive)\n    try:\n        r = client.chat.completions.create(\n            model=model,\n            messages=[\n                {\"role\": \"system\", \"content\": \"healthcheck\"},\n                {\"role\": \"user\", \"content\": \"ping\"}\n            ],\n            max_tokens=1,\n            temperature=0\n        )\n        used = getattr(r, \"usage\", None)\n        total = used.total_tokens if used else \"?\"\n        print(f\"✓ chat.completions.create OK (tokens_used={total})\")\n        return True\n    except Exception as e:\n        print(f\"✗ chat.completions failed: {e}\")\n        return False\n\nsanity_ok = sanity_check_openai_model(config.llm_model)\nprint(\"Model enabled:\", \"YES\" if sanity_ok else \"NO\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-10-29T02:07:26.100107Z","iopub.execute_input":"2025-10-29T02:07:26.100394Z","iopub.status.idle":"2025-10-29T02:07:27.475446Z","shell.execute_reply.started":"2025-10-29T02:07:26.100372Z","shell.execute_reply":"2025-10-29T02:07:27.474707Z"},"id":"tTJNWXhAVX5Y","outputId":"1be046ca-8ef9-4664-ea74-b5e203246bb2"},"outputs":[{"name":"stdout","text":"✓ tiktoken encoding loaded for gpt-4o-mini: o200k_base\n✓ models.retrieve OK: gpt-4o-mini\n✓ chat.completions.create OK (tokens_used=15)\nModel enabled: YES\n","output_type":"stream"}],"execution_count":39},{"cell_type":"code","source":"#Tool Implementation\n\nclass CodeTools:\n    \"\"\"Tools for fine-grained code access\"\"\"\n\n    def __init__(self, repo_dir: Path, chunks: List[Dict]):\n        self.repo_dir = repo_dir\n        self.chunks = chunks\n\n        # Build symbol index\n        self.symbol_index = self._build_symbol_index()\n\n    def _build_symbol_index(self) -> Dict[str, List[Dict]]:\n        \"\"\"Build index of symbols to locations\"\"\"\n        index = defaultdict(list)\n\n        for chunk in self.chunks:\n            # Index functions\n            for func in chunk['functions']:\n                index[func['name']].append({\n                    'type': 'function',\n                    'file': chunk['file_path'],\n                    'line': func['lineno'],\n                    'chunk_id': chunk['chunk_id']\n                })\n\n            # Index classes\n            for cls in chunk['classes']:\n                index[cls['name']].append({\n                    'type': 'class',\n                    'file': chunk['file_path'],\n                    'line': cls['lineno'],\n                    'chunk_id': chunk['chunk_id']\n                })\n\n        return dict(index)\n\n    def open_file(self, file_path: str, start_line: Optional[int] = None,\n                  end_line: Optional[int] = None) -> str:\n        \"\"\"Open and read a file\"\"\"\n        try:\n            full_path = self.repo_dir / file_path\n\n            with open(full_path, 'r', encoding='utf-8') as f:\n                lines = f.readlines()\n\n            if start_line and end_line:\n                lines = lines[start_line-1:end_line]\n                result = ''.join(lines)\n                return f\"File: {file_path} (lines {start_line}-{end_line})\\n\\n{result}\"\n            else:\n                return f\"File: {file_path}\\n\\n{''.join(lines)}\"\n\n        except Exception as e:\n            return f\"Error reading file: {e}\"\n\n    def grep_symbol(self, symbol: str) -> str:\n        \"\"\"Search for symbol across codebase\"\"\"\n        if symbol not in self.symbol_index:\n            return f\"Symbol '{symbol}' not found in index\"\n\n        locations = self.symbol_index[symbol]\n        result = [f\"Found {len(locations)} occurrences of '{symbol}':\\n\"]\n\n        for loc in locations[:10]:  # Limit to 10\n            result.append(\n                f\"  - {loc['type']}: {loc['file']}:{loc['line']}\"\n            )\n\n        if len(locations) > 10:\n            result.append(f\"  ... and {len(locations) - 10} more\")\n\n        return '\\n'.join(result)\n\n    def show_definition(self, symbol: str, file_path: Optional[str] = None) -> str:\n        \"\"\"Show definition of a symbol\"\"\"\n        if symbol not in self.symbol_index:\n            return f\"Symbol '{symbol}' not found\"\n\n        locations = self.symbol_index[symbol]\n\n        # Filter by file if specified\n        if file_path:\n            locations = [l for l in locations if file_path in l['file']]\n\n        if not locations:\n            return f\"Symbol '{symbol}' not found in {file_path}\"\n\n        # Use first location\n        loc = locations[0]\n\n        # Find the chunk containing this symbol\n        chunk = next((c for c in self.chunks if c['chunk_id'] == loc['chunk_id']), None)\n\n        if not chunk:\n            return f\"Chunk not found for {symbol}\"\n\n        return f\"{loc['type']} {symbol} in {loc['file']}:{loc['line']}\\n\\n```{chunk['language']}\\n{chunk['content']}\\n```\"\n\n    def show_diff(self, file_path: str, old_content: str, new_content: str) -> str:\n        \"\"\"Show diff between old and new content\"\"\"\n        import difflib\n\n        diff = difflib.unified_diff(\n            old_content.splitlines(keepends=True),\n            new_content.splitlines(keepends=True),\n            fromfile=f\"{file_path} (old)\",\n            tofile=f\"{file_path} (new)\"\n        )\n\n        return ''.join(diff)\n\n    def execute_tool(self, tool_name: str, arguments: Dict[str, Any]) -> str:\n        \"\"\"Execute a tool by name\"\"\"\n        if tool_name == \"open_file\":\n            return self.open_file(**arguments)\n        elif tool_name == \"grep_symbol\":\n            return self.grep_symbol(**arguments)\n        elif tool_name == \"show_definition\":\n            return self.show_definition(**arguments)\n        else:\n            return f\"Unknown tool: {tool_name}\"\n\n# Initialize tools\ncode_tools = CodeTools(repo_dir, all_chunks)\n\n# Test tool